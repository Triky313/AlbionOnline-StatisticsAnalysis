<UserControl x:Class="StatisticsAnalysisTool.UserControls.ItemSearchControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             xmlns:viewModels="clr-namespace:StatisticsAnalysisTool.ViewModels"
             xmlns:models="clr-namespace:StatisticsAnalysisTool.Models"
             xmlns:userControls="clr-namespace:StatisticsAnalysisTool.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel}">

    <Grid Style="{StaticResource TabItemGridStyle}" Visibility="Visible">
        <StackPanel Orientation="Vertical">
            <Grid>
                <TextBox x:Name="TxtSearch" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                         IsEnabled="{Binding IsTxtSearchEnabled, FallbackValue=false}" Style="{StaticResource ItemSearchTextBoxStyle}" />

                <Grid Margin="235,11,0,0" Height="20" Width="20" VerticalAlignment="Top" HorizontalAlignment="Left" IsEnabled="{Binding IsFilterResetEnabled, FallbackValue=false}">
                    <fa5:ImageAwesome Icon="Solid_Redo" Foreground="{StaticResource SolidColorBrush.Text.1}" MouseUp="FilterReset_MouseUp" />
                </Grid>
            </Grid>
            <StackPanel Orientation="Horizontal">
                <ComboBox ItemsSource="{Binding ItemShopCategories}" SelectedItem="{Binding SelectedItemShopCategory, Mode=TwoWay}" 
                          SelectedValuePath="Id" DisplayMemberPath="DisplayName" HorizontalAlignment="Left" Margin="10,5,5,5" VerticalAlignment="Top" Width="150" />
                <ComboBox ItemsSource="{Binding ItemSubCategories1}" SelectedItem="{Binding SelectedItemShopSubCategory1, Mode=TwoWay}" 
                          SelectedValuePath="Id" DisplayMemberPath="DisplayName" HorizontalAlignment="Left" Margin="5,5" VerticalAlignment="Top" Width="150" />
                <ComboBox ItemsSource="{Binding ItemSubCategories2}" SelectedItem="{Binding SelectedItemShopSubCategory2, Mode=TwoWay}" 
                          SelectedValuePath="Id" DisplayMemberPath="DisplayName" HorizontalAlignment="Left" Margin="5,5" VerticalAlignment="Top" Width="150" />
                <ComboBox ItemsSource="{Binding ItemSubCategories3}" SelectedItem="{Binding SelectedItemShopSubCategory3, Mode=TwoWay}" 
                          SelectedValuePath="Id" DisplayMemberPath="DisplayName" HorizontalAlignment="Left" Margin="5,5" VerticalAlignment="Top" Width="150" />

                <ComboBox ItemsSource="{Binding ItemTiers}" SelectedValue="{Binding SelectedItemTier}" 
                          SelectedValuePath="Key" DisplayMemberPath="Value" HorizontalAlignment="Left" Margin="5,5" MinWidth="70" />
                <ComboBox ItemsSource="{Binding ItemLevels}" SelectedValue="{Binding SelectedItemLevel}" 
                          SelectedValuePath="Key" DisplayMemberPath="Value" HorizontalAlignment="Left" Margin="5,5" MinWidth="70" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" IsEnabled="{Binding IsItemSearchCheckboxesEnabled}">
                <CheckBox Content="{Binding Translation.ShowOnlyItemsWithAlertOn, FallbackValue=SHOW__ONLY__ITEMS__WITH__ALERT__ON}" 
                          IsChecked="{Binding IsShowOnlyItemsWithAlertOnActive, FallbackValue=false}" HorizontalAlignment="Left" Margin="10,0,5,0" />
                <CheckBox Content="{Binding Translation.ShowOnlyFavorites, FallbackValue=SHOW__ONLY__FAVORITES}" 
                          IsChecked="{Binding IsShowOnlyFavoritesActive, FallbackValue=false}" HorizontalAlignment="Left" Margin="5,0,5,0" />
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Right">
            <userControls:ItemSearchImageCounterControl LocalImageCounter="{Binding LocalImageCounter}"
                                                        ItemCounterString="{Binding ItemCounterString}" />
            <Grid Height="20" Width="20" Margin="0,4,10,0" HorizontalAlignment="Right" VerticalAlignment="Top"
                  MouseEnter="OpenItemSearchInfoPopup_MouseEnter" MouseLeave="CloseItemSearchInfoPopup_MouseLeave">
                <fa5:ImageAwesome Icon="Solid_InfoCircle" Foreground="{StaticResource SolidColorBrush.Text.1}" />
            </Grid>
        </StackPanel>

        <ListView SnapsToDevicePixels="True" ItemsSource="{Binding ItemsView}" ItemContainerStyle="{StaticResource {x:Type ListViewItem}}"
                  ScrollViewer.CanContentScroll="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  Margin="0,90,0,0" SelectionMode="Single" MouseDoubleClick="LvItems_MouseDoubleClick" d:ItemsSource="{d:SampleData ItemCount=5}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="{Binding Translation.Icon, FallbackValue=ICON}" Width="80" CellTemplate="{StaticResource ItemSearch.GridViewColumnIconTemplate}"/>
                    <GridViewColumn Header="{Binding Translation.Name, FallbackValue=NAME}" Width="400" CellTemplate="{StaticResource ItemSearch.GridViewColumnNameTemplate}" />
                    <GridViewColumn Header="{Binding Translation.IsAlertActive, FallbackValue=IS_ALERT_ACTIVE}" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <!--TODO: Rework alert toggles and without style in this file!-->
                                <Grid Height="24" Width="24">
                                    <fa5:ImageAwesome Visibility="Visible" MouseUp="AlertModeAlertActiveToggle_MouseUp">
                                        <fa5:ImageAwesome.Style>
                                            <Style TargetType="{x:Type fa5:ImageAwesome}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding (models:Item.IsAlertActive)}" Value="True">
                                                        <Setter Property="Icon" Value="Solid_ToggleOn"/>
                                                        <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Blue.2}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding (models:Item.IsAlertActive)}" Value="False">
                                                        <Setter Property="Icon" Value="Solid_ToggleOff"/>
                                                        <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Text.1}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </fa5:ImageAwesome.Style>
                                    </fa5:ImageAwesome>
                                </Grid>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="{Binding Translation.UndercuttingPrice, FallbackValue=UNDERCUTTING_PRICE}" Width="80" 
                                    CellTemplate="{StaticResource ItemSearch.GridViewColumnAlertMinSellPriceTemplate}" />
                    <GridViewColumn Header="{Binding Translation.Favorite, FallbackValue=FAVORITE}" Width="80" CellTemplate="{StaticResource ItemSearch.GridViewColumnFavoriteTemplate}" />
                </GridView>
            </ListView.View>
        </ListView>

        <Grid Visibility="{Binding IsItemSearchPopupVisible, FallbackValue=Hidden}" Margin="0,90,0,0" Background="{StaticResource SolidColorBrush.Background.2}">
            <StackPanel CanHorizontallyScroll="False" CanVerticallyScroll="True" Margin="10,0">
                <DockPanel Margin="0,0,0,16">
                    <Grid Height="16" Width="16" Margin="0,3,10,0" VerticalAlignment="Top">
                        <fa5:ImageAwesome Icon="Regular_DotCircle" Foreground="{StaticResource SolidColorBrush.Accent.Blue.3}" />
                    </Grid>
                    <TextBlock Text="{Binding Translation.ItemSearchDescription1, FallbackValue='Item Info Fenster: Das Item Info Fenster kann via Doppelklick auf dem Item selbst in der Liste geoeffnet werden.'}"
                               Foreground="{StaticResource SolidColorBrush.Text.1}"
                               FontSize="16" TextWrapping="Wrap" Width="auto" />
                </DockPanel>
                <DockPanel Margin="0,0,0,16">
                    <Grid Height="16" Width="16" Margin="0,3,10,0" VerticalAlignment="Top">
                        <fa5:ImageAwesome Icon="Regular_DotCircle" Foreground="{StaticResource SolidColorBrush.Accent.Blue.3}" />
                    </Grid>
                    <TextBlock Text="{Binding Translation.ItemSearchDescription2, FallbackValue='Item Alarm: Trage einen Wert in der Unterbieten Spalte ein und aktiviere den Alarm dann in der Ist Alarm aktiv Spalte.'}"
                               Foreground="{StaticResource SolidColorBrush.Text.1}"
                               FontSize="16" TextWrapping="Wrap" Width="auto" />
                </DockPanel>
                <DockPanel Margin="0,0,0,16">
                    <Grid Height="16" Width="16" Margin="0,3,10,0" VerticalAlignment="Top">
                        <fa5:ImageAwesome Icon="Regular_DotCircle" Foreground="{StaticResource SolidColorBrush.Accent.Blue.3}" />
                    </Grid>
                    <TextBlock Text="{Binding Translation.ItemSearchDescription3, FallbackValue='Item Preise: Preise unter den Item Namen in der Liste sind Durchschnittswerte direkt aus dem Spiel und passen sich an, wenn Items im Spiel angesehen werden.'}"
                               Foreground="{StaticResource SolidColorBrush.Text.1}"
                               FontSize="16" TextWrapping="Wrap" Width="auto" />
                </DockPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>