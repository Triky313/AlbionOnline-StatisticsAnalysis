<UserControl x:Class="StatisticsAnalysisTool.UserControls.LoggingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
             xmlns:eventLogging="clr-namespace:StatisticsAnalysisTool.EventLogging"
             xmlns:viewModels="clr-namespace:StatisticsAnalysisTool.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel}">
    <UserControl.Resources>
        <Style x:Key="Logging.DropdownButton" TargetType="{x:Type ToggleButton}">
            <Setter Property="SnapsToDevicePixels" Value="true" />
            <Setter Property="OverridesDefaultStyle" Value="true" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource ButtonFocusVisual}" />
            <Setter Property="MinHeight" Value="25" />
            <Setter Property="MinWidth" Value="115" />
            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Text.1}" />
            <Setter Property="Background" Value="{StaticResource SolidColorBrush.Background.2}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource SolidColorBrush.Text.1}" BorderThickness="1"
                                TextBlock.Foreground="{TemplateBinding Foreground}">
                            <DockPanel Margin="7,2">
                                <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="8" Margin="8,0,0,0"
                                           VerticalAlignment="Center" DockPanel.Dock="Right" />
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" RecognizesAccessKey="True" />
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SolidColorBrush.Background.3}" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource SolidColorBrush.Accent.Blue.2}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SolidColorBrush.Background.3}" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource SolidColorBrush.Accent.Blue.2}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SolidColorBrush.Text.6}" />
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource SolidColorBrush.Text.4}" />
                                <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Text.4}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Logging.ImportButton" TargetType="{x:Type Button}">
            <Setter Property="SnapsToDevicePixels" Value="true" />
            <Setter Property="OverridesDefaultStyle" Value="true" />
            <Setter Property="FocusVisualStyle" Value="{StaticResource ButtonFocusVisual}" />
            <Setter Property="MinHeight" Value="18px" />
            <Setter Property="MinWidth" Value="40px" />
            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Text.7}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" TextBlock.Foreground="{TemplateBinding Foreground}">
                            <ContentPresenter Margin="2"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource SolidColorBrush.Text.6}" />
                                <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Text.4}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Logging.ImportButton.Yellow" TargetType="{x:Type Button}" BasedOn="{StaticResource Logging.ImportButton}">
            <Setter Property="Background" Value="{StaticResource SolidColorBrush.Accent.Yellow.1}" />
        </Style>

        <Style x:Key="Logging.ImportButton.Orange" TargetType="{x:Type Button}" BasedOn="{StaticResource Logging.ImportButton}">
            <Setter Property="Background" Value="{StaticResource SolidColorBrush.Accent.Orange.2}" />
        </Style>

        <DataTemplate x:Key="LootLoggerStatsEntryTemplate" DataType="{x:Type eventLogging:LootLoggerStatsEntry}">
            <StackPanel Margin="0,0,0,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Rank, StringFormat='{}{0}.'}"
                               Foreground="{StaticResource SolidColorBrush.Text.2}" FontSize="15" FontWeight="Bold" />
                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                               Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="15" TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="2" Text="{Binding ValueString}"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                               HorizontalAlignment="Right" FontSize="15" FontWeight="Bold" />
                </Grid>
                <TextBlock Margin="24,-1,0,0" Foreground="{StaticResource SolidColorBrush.Text.3}" FontSize="13"
                           Visibility="{Binding DetailVisibility}" TextTrimming="CharacterEllipsis">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0}: {1}">
                            <Binding Path="DataContext.LoggingBindings.Translation.Killer" RelativeSource="{RelativeSource AncestorType={x:Type UserControl}}" FallbackValue="Killer" />
                            <Binding Path="Detail" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="LootLoggerStatsDetailEntryTemplate" DataType="{x:Type eventLogging:LootLoggerStatsEntry}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="46"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Rank, StringFormat='{}{0}.'}" Foreground="{StaticResource SolidColorBrush.Text.2}" 
                               FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />
                    <Image Grid.Column="1" Source="{Binding Icon}" Width="36" Height="36" Stretch="Fill" Margin="0,4,0,0"
                           Visibility="{Binding IconVisibility}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="16" TextTrimming="CharacterEllipsis" />
                        <TextBlock Foreground="{StaticResource SolidColorBrush.Accent.Blue.1}" FontSize="12" 
                                   Visibility="{Binding DetailVisibility}" Text="{Binding Detail}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <TextBlock Grid.Column="3" Text="{Binding ValueString}" 
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}" 
                               HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="20" FontWeight="Bold" />
                </Grid>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="LootLoggerStatsTemplate" DataType="{x:Type eventLogging:LootLoggerStats}">
            <Grid Margin="0,5,0,0">
                <ScrollViewer>
                    <UniformGrid Columns="2">
                        <Border Margin="0,2,10,4" Padding="4,3" BorderBrush="{StaticResource SolidColorBrush.Accent.Yellow.3}" BorderThickness="0,1,0,0">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.LoggingBindings.Translation.LootStats, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue='Loot'}"
                                           Foreground="{StaticResource SolidColorBrush.Accent.Yellow.3}" FontWeight="Bold" Margin="0,0,0,2" FontSize="16" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="125"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DataContext.LoggingBindings.Translation.TotalLootValue, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue='Total Loot Value'}"
                                               Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" Margin="0,0,0,2" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalLootValue}" Foreground="{StaticResource SolidColorBrush.Accent.Yellow.3}"
                                               HorizontalAlignment="Right" FontSize="15" FontWeight="Bold" Margin="0,0,0,2" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding DataContext.LoggingBindings.Translation.LootValuePerHour, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue='Loot Value per Hour'}"
                                               Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LootValuePerHour}" Foreground="{StaticResource SolidColorBrush.Accent.Yellow.3}"
                                               HorizontalAlignment="Right" FontSize="15" FontWeight="Bold" />
                                </Grid>
                            </DockPanel>
                        </Border>

                        <Border Margin="10,2,0,8" Padding="5" BorderBrush="{StaticResource SolidColorBrush.Accent.Yellow.3}" BorderThickness="0,1,0,0">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.LoggingBindings.Translation.BestSingleLoot, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue='Best Single Item'}"
                                           Foreground="{StaticResource SolidColorBrush.Accent.Yellow.3}" FontWeight="Bold" Margin="0,0,0,5" FontSize="16" />
                                <ItemsControl ItemsSource="{Binding BestSingleLoots}" ItemTemplate="{StaticResource LootLoggerStatsDetailEntryTemplate}"
                                              Foreground="{StaticResource SolidColorBrush.Accent.Yellow.3}" />
                            </DockPanel>
                        </Border>

                        <Border Margin="0,2,10,8" Padding="5" BorderBrush="{StaticResource SolidColorBrush.Value.Silver}" BorderThickness="0,1,0,0">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.LoggingBindings.Translation.HighestKillValue, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue='Highest Kill Value'}"
                                           Foreground="{StaticResource SolidColorBrush.Value.Silver}" FontWeight="Bold" Margin="0,0,0,5" FontSize="16" />
                                <ItemsControl ItemsSource="{Binding HighestKillValues}" ItemTemplate="{StaticResource LootLoggerStatsEntryTemplate}"
                                              Foreground="{StaticResource SolidColorBrush.Value.Silver}" />
                            </DockPanel>
                        </Border>

                        <Border Margin="10,2,0,8" Padding="5" BorderBrush="{StaticResource SolidColorBrush.Accent.Green.3}" BorderThickness="0,1,0,0">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.LoggingBindings.Translation.HighestLootedValue, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue='Highest Looted Value'}"
                                           Foreground="{StaticResource SolidColorBrush.Accent.Green.3}" FontWeight="Bold" Margin="0,0,0,5" FontSize="16" />
                                <ItemsControl ItemsSource="{Binding HighestLootedValues}" ItemTemplate="{StaticResource LootLoggerStatsEntryTemplate}"
                                              Foreground="{StaticResource SolidColorBrush.Accent.Green.3}" />
                            </DockPanel>
                        </Border>

                        <Border Margin="0,2,10,8" Padding="5" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.2}" BorderThickness="0,1,0,0">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.LoggingBindings.Translation.MostLootedItems, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue='Most Looted Items'}"
                                           Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" FontWeight="Bold" Margin="0,0,0,5" FontSize="16" />
                                <ItemsControl ItemsSource="{Binding MostLootedItems}" ItemTemplate="{StaticResource LootLoggerStatsEntryTemplate}"
                                              Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" />
                            </DockPanel>
                        </Border>

                        <Border Margin="10,2,0,8" Padding="5" BorderBrush="{StaticResource SolidColorBrush.Accent.Red.2}" BorderThickness="0,1,0,0">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.LoggingBindings.Translation.MostKills, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue='Most Kills'}"
                                           Foreground="{StaticResource SolidColorBrush.Accent.Red.2}" FontWeight="Bold" Margin="0,0,0,5" FontSize="16" />
                                <ItemsControl ItemsSource="{Binding MostKills}" ItemTemplate="{StaticResource LootLoggerStatsEntryTemplate}"
                                              Foreground="{StaticResource SolidColorBrush.Accent.Red.2}" />
                            </DockPanel>
                        </Border>

                        <Border Margin="0,2,10,8" Padding="5" BorderBrush="{StaticResource SolidColorBrush.Accent.Orange.3}" BorderThickness="0,1,0,0">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.LoggingBindings.Translation.MostDeaths, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue='Most Deaths'}"
                                           Foreground="{StaticResource SolidColorBrush.Accent.Orange.3}" FontWeight="Bold" Margin="0,0,0,5" FontSize="16" />
                                <ItemsControl ItemsSource="{Binding MostDeaths}" ItemTemplate="{StaticResource LootLoggerStatsEntryTemplate}"
                                              Foreground="{StaticResource SolidColorBrush.Accent.Orange.3}" />
                            </DockPanel>
                        </Border>
                    </UniformGrid>
                </ScrollViewer>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <TabControl Background="Transparent" BorderThickness="0">
            <TabItem Header="{Binding Translation.Logging, FallbackValue=LOGGING}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,5,0,5">
                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,285,0">
                            <TextBox Text="{Binding LoggingSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="240" Height="25" Margin="0,0,6,0" />

                            <StackPanel Margin="0,0,6,0">
                                <ToggleButton x:Name="NotificationFilterButton" Style="{StaticResource Logging.DropdownButton}"
                                              Content="{Binding LoggingBindings.NotificationFilterSummary, FallbackValue='Filter: All'}" />
                                <Popup PlacementTarget="{Binding ElementName=NotificationFilterButton}"
                                       IsOpen="{Binding IsChecked, ElementName=NotificationFilterButton, Mode=TwoWay}"
                                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                    <Border DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type Popup}}}"
                                            Background="{StaticResource SolidColorBrush.Background.2}" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}"
                                            BorderThickness="1" Padding="8">
                                        <ItemsControl MinWidth="190" ItemsSource="{Binding LoggingBindings.Filters}" ItemTemplate="{StaticResource LoggingFilterObject}" />
                                    </Border>
                                </Popup>
                            </StackPanel>

                            <StackPanel Margin="0,0,6,0" Orientation="Horizontal">
                                <ToggleButton x:Name="TrackingSettingsButton" Style="{StaticResource Logging.DropdownButton}"
                                              Content="{Binding LoggingBindings.TrackingSummary, FallbackValue='Tracking: All'}" />
                                <Popup PlacementTarget="{Binding ElementName=TrackingSettingsButton}"
                                       IsOpen="{Binding IsChecked, ElementName=TrackingSettingsButton, Mode=TwoWay}"
                                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                    <Border DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type Popup}}}"
                                            Background="{StaticResource SolidColorBrush.Background.2}" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}"
                                            BorderThickness="1" Padding="8">
                                        <StackPanel MinWidth="180">
                                            <CheckBox IsChecked="{Binding LoggingBindings.IsTrackingPartyLootOnly, FallbackValue=true}"
                                                      Content="{Binding Translation.TrackPartyLootOnly, FallbackValue=TRACK__PARTY__LOOT__ONLY}" />
                                            <CheckBox IsChecked="{Binding LoggingBindings.IsTrackingSilver, FallbackValue=true}"
                                                      Content="{Binding Translation.TrackingSilver, FallbackValue=TRACKING__SILVER}" />
                                            <CheckBox IsChecked="{Binding LoggingBindings.IsTrackingFame, FallbackValue=true}"
                                                      Content="{Binding Translation.TrackingFame, FallbackValue=TRACKING__FAME}" />
                                            <CheckBox IsChecked="{Binding LoggingBindings.IsTrackingMobLoot, FallbackValue=true}"
                                                      Content="{Binding Translation.TrackingMobLoot, FallbackValue=TRACKING__MOB__LOOT}" />
                                            <CheckBox IsChecked="{Binding LoggingBindings.IsTrackingKill, FallbackValue=true}"
                                                      Content="{Binding Translation.ShowKills, FallbackValue=KILL__TRACKING}" />
                                        </StackPanel>
                                    </Border>
                                </Popup>

                                <Grid Height="24" Width="24" Margin="5,0,5,0" VerticalAlignment="Center">
                                    <fa5:ImageAwesome Icon="Solid_FileCsv" ToolTip="{Binding Translation.ExportLootToFile}"
                                                      Foreground="{StaticResource SolidColorBrush.Accent.Green.4}" MouseUp="BtnExportLootToFile_MouseUp" />
                                </Grid>
                                <Grid Height="24" Width="24" Margin="5,0,0,0" VerticalAlignment="Center">
                                    <fa5:ImageAwesome Icon="Solid_FileCode" ToolTip="{Binding Translation.ExportLootToJsonFile}"
                                                      Foreground="{StaticResource SolidColorBrush.Accent.Green.4}" MouseUp="BtnExportLootToJsonFile_MouseUp" />
                                </Grid>
                            </StackPanel>
                        </WrapPanel>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Orientation="Horizontal" Margin="0,0,5,0">
                            <Button Content="{Binding Translation.ResetTrackingNotifications, FallbackValue=RESET__TRACKING__NOTIFICATIONS}"
                                    Height="26" MaxWidth="500" MinWidth="210" Margin="0,0,0,5"
                                    Width="Auto" VerticalAlignment="Top" Style="{StaticResource Style.Button.Danger}"
                                    Click="BtnTrackingNotificationsReset_Click" />
                        </StackPanel>
                    </Grid>

                    <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
                        <TabItem Header="{Binding LoggingBindings.Translation.Notifications, FallbackValue=NOTIFICATIONS}">
                            <ListBox Background="Transparent"
                                     BorderThickness="0"
                                     ItemsSource="{Binding LoggingBindings.GameLoggingCollectionView, IsAsync=True, Mode=OneWay}"
                                     ItemTemplate="{StaticResource NotificationTemplate}"
                                     ScrollViewer.CanContentScroll="True"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Visible"
                                     VirtualizingPanel.CacheLengthUnit="Item"
                                     VirtualizingPanel.CacheLength="20,20"
                                     VirtualizingPanel.IsContainerVirtualizable="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.ScrollUnit="Pixel"
                                     VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="{x:Type ListBoxItem}">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Focusable" Value="False" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                                    <ContentPresenter />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </TabItem>
                        <TabItem Header="{Binding LoggingBindings.Translation.Stats, FallbackValue=STATS}">
                            <ContentControl Content="{Binding LoggingBindings.LootLoggerStats}" ContentTemplate="{StaticResource LootLoggerStatsTemplate}" />
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>
            <TabItem Header="{Binding Translation.LootComparator, FallbackValue=LOOT__COMPARATOR}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,5,0,5" IsEnabled="{Binding LoggingBindings.IsAllButtonsEnabled}">
                        <StackPanel Orientation="Vertical">
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0" VerticalAlignment="Top">
                                <StackPanel Margin="0,0,6,0">
                                    <ToggleButton x:Name="StatusFilterButton" Style="{StaticResource Logging.DropdownButton}"
                      Content="{Binding LoggingBindings.StatusFilterSummary, FallbackValue='Status: All'}" />
                                    <Popup PlacementTarget="{Binding ElementName=StatusFilterButton}"
               IsOpen="{Binding IsChecked, ElementName=StatusFilterButton, Mode=TwoWay}"
               Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                        <Border DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type Popup}}}"
                    Background="{StaticResource SolidColorBrush.Background.2}" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}"
                    BorderThickness="1" Padding="8">
                                            <StackPanel MinWidth="130">
                                                <CheckBox IsChecked="{Binding LoggingBindings.IsShowingLost, FallbackValue=true}"
                              Content="{Binding LoggingBindings.Translation.Lost, FallbackValue=LOST}" />
                                                <CheckBox IsChecked="{Binding LoggingBindings.IsShowingResolved, FallbackValue=true}"
                              Content="{Binding LoggingBindings.Translation.Resolved, FallbackValue=RESOLVED}" />
                                                <CheckBox IsChecked="{Binding LoggingBindings.IsShowingDonated, FallbackValue=true}"
                              Content="{Binding LoggingBindings.Translation.Donated, FallbackValue=DONATED}" />
                                                <CheckBox IsChecked="{Binding LoggingBindings.IsShowingTrash, FallbackValue=true}"
                              Content="{Binding LoggingBindings.Translation.Trash, FallbackValue=TRASH}" />
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </StackPanel>

                                <StackPanel Margin="0,0,6,0">
                                    <ToggleButton x:Name="TierFilterButton" Style="{StaticResource Logging.DropdownButton}"
                      Content="{Binding LoggingBindings.TierFilterSummary, FallbackValue='Tier: All'}" />
                                    <Popup PlacementTarget="{Binding ElementName=TierFilterButton}"
               IsOpen="{Binding IsChecked, ElementName=TierFilterButton, Mode=TwoWay}"
               Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                        <Border DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type Popup}}}"
                    Background="{StaticResource SolidColorBrush.Background.2}" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}"
                    BorderThickness="1" Padding="8">
                                            <StackPanel MinWidth="130">
                                                <CheckBox IsChecked="{Binding LoggingBindings.IsShowingT1ToT3, FallbackValue=true}"
                              Content="{Binding LoggingBindings.Translation.T1ToT3, FallbackValue=T1-T3}" />
                                                <CheckBox IsChecked="{Binding LoggingBindings.IsShowingT4, FallbackValue=true}"
                              Content="{Binding LoggingBindings.Translation.T4, FallbackValue=T4}" />
                                                <CheckBox IsChecked="{Binding LoggingBindings.IsShowingT5, FallbackValue=true}"
                              Content="{Binding LoggingBindings.Translation.T5, FallbackValue=T5}" />
                                                <CheckBox IsChecked="{Binding LoggingBindings.IsShowingT6, FallbackValue=true}"
                              Content="{Binding LoggingBindings.Translation.T6, FallbackValue=T6}" />
                                                <CheckBox IsChecked="{Binding LoggingBindings.IsShowingT7, FallbackValue=true}"
                              Content="{Binding LoggingBindings.Translation.T7, FallbackValue=T7}" />
                                                <CheckBox IsChecked="{Binding LoggingBindings.IsShowingT8, FallbackValue=true}"
                              Content="{Binding LoggingBindings.Translation.T8, FallbackValue=T8}" />
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </StackPanel>

                                <StackPanel Margin="0,0,6,0">
                                    <ToggleButton x:Name="TypeFilterButton" Style="{StaticResource Logging.DropdownButton}" 
                                                  Content="{Binding LoggingBindings.TypeFilterSummary, FallbackValue='Type: All'}" />
                                    <Popup PlacementTarget="{Binding ElementName=TypeFilterButton}" IsOpen="{Binding IsChecked, ElementName=TypeFilterButton, Mode=TwoWay}" 
                                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                        <Border DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type Popup}}}" 
                                                Background="{StaticResource SolidColorBrush.Background.2}" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}" 
                                                BorderThickness="1" Padding="8">
                                            <StackPanel MinWidth="130">
                                                <CheckBox IsChecked="{Binding LoggingBindings.IsShowingFood, FallbackValue=true}" 
                                                          Content="{Binding LoggingBindings.Translation.Food, FallbackValue=FOOD}" />
                                                <CheckBox IsChecked="{Binding LoggingBindings.IsShowingPotion, FallbackValue=true}" 
                                                          Content="{Binding LoggingBindings.Translation.Potion, FallbackValue=POTION}" />
                                                <CheckBox IsChecked="{Binding LoggingBindings.IsShowingBag, FallbackValue=true}" 
                                                          Content="{Binding LoggingBindings.Translation.Bag, FallbackValue=BAG}" />
                                                <CheckBox IsChecked="{Binding LoggingBindings.IsShowingCape, FallbackValue=true}"
                                                          Content="{Binding LoggingBindings.Translation.Cape, FallbackValue=CAPE}" />
                                                <CheckBox IsChecked="{Binding LoggingBindings.IsShowingWeapon, FallbackValue=true}"
                                                          Content="{Binding LoggingBindings.Translation.Weapon, FallbackValue=WEAPON}" />
                                                <CheckBox IsChecked="{Binding LoggingBindings.IsShowingArmor, FallbackValue=true}"
                                                          Content="{Binding LoggingBindings.Translation.Armor, FallbackValue=ARMOR}" />
                                                <CheckBox IsChecked="{Binding LoggingBindings.IsShowingMount, FallbackValue=true}"
                                                          Content="{Binding LoggingBindings.Translation.Mount, FallbackValue=MOUNT}" />
                                                <CheckBox IsChecked="{Binding LoggingBindings.IsShowingOthers, FallbackValue=true}" 
                                                          Content="{Binding LoggingBindings.Translation.Others, FallbackValue=OTHERS}" />
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </StackPanel>

                                <StackPanel>
                                    <ToggleButton x:Name="GuildFilterButton" Style="{StaticResource Logging.DropdownButton}"
                                                  Content="{Binding LoggingBindings.GuildFilterSummary, FallbackValue='Guild: All'}" />
                                    <Popup PlacementTarget="{Binding ElementName=GuildFilterButton}"
                                           IsOpen="{Binding IsChecked, ElementName=GuildFilterButton, Mode=TwoWay}"
                                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                        <Border DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type Popup}}}"
                                                Background="{StaticResource SolidColorBrush.Background.2}" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}"
                                                BorderThickness="1" Padding="8">
                                            <ScrollViewer MinWidth="130" MaxHeight="260" VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding LoggingBindings.LootComparatorGuildFilters}" ItemTemplate="{StaticResource LoggingFilterObject}" />
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Margin="0,5,0,0">
                                <TextBlock Text="{Binding LoggingBindings.LootComparatorLogCountSummary, FallbackValue='0 chest files | 0 loot log files'}"
                                           ToolTip="{Binding LoggingBindings.LootComparatorLogCountTooltip, FallbackValue='Shows how many chest log sources and loot log files were added.'}"
                                           Foreground="{StaticResource SolidColorBrush.Text.3}" FontSize="13"
                                           Margin="5,0,0,3" VerticalAlignment="Center" />
                                <Grid Width="320" Height="50" HorizontalAlignment="Left">
                                    <TextBox Text="{Binding LoggingBindings.ChestLogText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                                             VerticalContentAlignment="Top" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" />
                                    <TextBlock Text="{Binding LoggingBindings.Translation.ChestLogTextPlaceholder, FallbackValue=Paste chest log here}"
                                               Foreground="{StaticResource SolidColorBrush.Text.5}"
                                               Opacity="0.55"
                                               Margin="6,4,0,0"
                                               IsHitTestVisible="False"
                                               Focusable="False">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LoggingBindings.ChestLogText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <Button Style="{StaticResource Logging.ImportButton.Yellow}" MinWidth="150" Height="25" Margin="0,0,5,0" Padding="10,0"
                                            Content="{Binding LoggingBindings.Translation.LoadChestLogText, FallbackValue=LOAD__CHEST__LOG__TEXT}"
                                            Click="BtnLoadVaultLogText_Click" />
                                    <Button Style="{StaticResource Logging.ImportButton.Yellow}" MinWidth="150" Height="25" Margin="5,0" Padding="10,0"
                                            Content="{Binding LoggingBindings.Translation.UploadChestFiles, FallbackValue=UPLOAD__CHEST__FILES}"
                                            VerticalAlignment="Top" Click="BtnLoadVaultLogFiles_Click" />
                                    <Button Style="{StaticResource Logging.ImportButton.Orange}" MinWidth="150" Height="25" Margin="5,0" Padding="10,0"
                                            Content="{Binding LoggingBindings.Translation.AddLootLogFiles, FallbackValue=ADD__LOOT__LOG__FILES}" VerticalAlignment="Top"
                                            Click="BtnAddLootLogFiles_Click" />
                                </StackPanel>
                                <TextBlock Text="{Binding LoggingBindings.LootComparatorImportEventLine}"
                                           Visibility="{Binding LoggingBindings.LootComparatorImportEventLineVisibility}"
                                           Foreground="{StaticResource SolidColorBrush.Accent.Red.2}"
                                           FontSize="12"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           MaxWidth="480" />
                            </StackPanel>
                        </StackPanel>

                        <Separator Background="{StaticResource SolidColorBrush.Background.3}" Width="1" Height="82" Margin="0,0,2,0" />

                        <StackPanel Orientation="Vertical">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <Button Style="{StaticResource Style.Button.Attention}" MinWidth="150" Height="25" Margin="0,0,5,0"
                                        Content="{Binding LoggingBindings.Translation.DeleteChestLogs, FallbackValue=DELETE__CHEST__FILE__LOGS}" VerticalAlignment="Top" Click="BtnClearVaultLogItems_Click" />
                                <Button Style="{StaticResource Style.Button.Attention}" MinWidth="150" Height="25" Margin="5,0,5,0"
                                        Content="{Binding LoggingBindings.Translation.DeleteAllLogs, FallbackValue=DELETE__ALL__LOGS}" VerticalAlignment="Top" Click="BtnClearLootLogs_Click" />
                                <Grid Height="20" Width="20" Margin="5,0,0,0" VerticalAlignment="Center"
                                      Cursor="Hand" MouseUp="ToggleLootComparatorInfoPopup_MouseUp">
                                    <fa5:ImageAwesome Icon="Solid_InfoCircle" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                                </Grid>
                            </StackPanel>
                            <Button MinWidth="150" Height="50" Margin="0,0,30,0" 
                                    Content="{Binding LoggingBindings.Translation.CompareLogs, FallbackValue=COMPARE__LOGS}" FontSize="20" Click="BtnLogCompare_Click" />
                        </StackPanel>
                    </StackPanel>
                    <Separator Grid.Row="2" Background="{StaticResource SolidColorBrush.Background.3}" Height="4" />
                    <vwp:VirtualizingItemsControl Grid.Row="3" ItemsSource="{Binding LoggingBindings.LootingPlayersCollectionView, IsAsync=True, Mode=OneWay}"
                                                  ItemTemplate="{StaticResource LootingPlayersTemplate}"
                                                  VirtualizingPanel.CacheLengthUnit="Item"
                                                  VirtualizingPanel.CacheLength="10,10"
                                                  VirtualizingPanel.ScrollUnit="Pixel"
                                                  VirtualizingPanel.VirtualizationMode="Standard"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                  ScrollViewer.VerticalScrollBarVisibility="Visible" />
                </Grid>
            </TabItem>
        </TabControl>
        <ScrollViewer Visibility="{Binding LoggingBindings.IsLootComparatorInfoPopupVisible, FallbackValue=Collapsed}"
                      Margin="0,52,0,0"
                      Background="{StaticResource SolidColorBrush.Background.2}"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      CanContentScroll="True"
                      PanningMode="VerticalOnly">
            <StackPanel Margin="10,0">
                <TextBlock Style="{StaticResource InfoDescription.Header}" Text="{Binding Translation.LootComparatorHeaderHowDoIGetTheChestLogs, FallbackValue=HOW_DO_I_GET_THE_CHEST_LOGS}" />
                <TextBlock Text="{Binding Translation.LootComparatorDescription1, FallbackValue=Description1}" Foreground="{StaticResource SolidColorBrush.Text.1}"
                           FontSize="16" TextWrapping="Wrap" Width="auto" Margin="0,0,0,10" />
                <TextBlock Text="{Binding Translation.LootComparatorDescription2, FallbackValue=Description2}" Foreground="{StaticResource SolidColorBrush.Text.1}"
                           FontSize="16" TextWrapping="Wrap" Width="auto" />
                <TextBlock Text="{Binding Translation.LootComparatorDescription3, FallbackValue=Description3}" Foreground="{StaticResource SolidColorBrush.Text.1}"
                           FontSize="16" TextWrapping="Wrap" Width="auto" />
                <TextBlock Text="{Binding Translation.LootComparatorDescription4, FallbackValue=Description4}" Foreground="{StaticResource SolidColorBrush.Text.1}"
                           FontSize="16" TextWrapping="Wrap" Width="auto" />
                <TextBlock Text="{Binding Translation.LootComparatorDescription5, FallbackValue=Description5}" Foreground="{StaticResource SolidColorBrush.Text.1}"
                           FontSize="16" TextWrapping="Wrap" Width="auto" Margin="0,0,0,10" />
                <TextBlock Text="{Binding Translation.LootComparatorDescription6, FallbackValue=Description6}" Foreground="{StaticResource SolidColorBrush.Text.1}"
                           FontSize="16" TextWrapping="Wrap" Width="auto" />
                <TextBlock Text="{Binding Translation.LootComparatorDescription7, FallbackValue=Description7}" Foreground="{StaticResource SolidColorBrush.Text.1}"
                           FontSize="16" TextWrapping="Wrap" Width="auto" />
                <Image Margin="0,10" Source="../Assets/loggingcomparator_description01.jpg" MaxWidth="1000" HorizontalAlignment="Left" />

                <TextBlock Style="{StaticResource InfoDescription.Header}" Text="{Binding Translation.LootComparatorWhatTheItemSlotsColorsMean, FallbackValue=WHAT_THE_ITEM_SLOTS_COLORS_MEAN}" />
                <Image Source="../Assets/loot_cpmparator_slot_gray.png" Height="50" Width="50" HorizontalAlignment="Left" />
                <TextBlock Text="{Binding Translation.LootComparatorSlotsColorsDescriptionGray, FallbackValue=LootComparatorSlotsColorsDescriptionGray}" Foreground="{StaticResource SolidColorBrush.Text.1}"
                           FontSize="16" TextWrapping="Wrap" Width="auto" Margin="0,0,0,20" />

                <Image Margin="0,0,0,0" Source="../Assets/loot_cpmparator_slot_green.png" Height="50" Width="50" HorizontalAlignment="Left" />
                <TextBlock Text="{Binding Translation.LootComparatorSlotsColorsDescriptionGreen, FallbackValue=LootComparatorSlotsColorsDescriptionGreen}" Foreground="{StaticResource SolidColorBrush.Text.1}"
                           FontSize="16" TextWrapping="Wrap" Width="auto" Margin="0,0,0,20" />

                <Image Margin="0,0,0,0" Source="../Assets/loot_cpmparator_slot_blue.png" Height="50" Width="50" HorizontalAlignment="Left" />
                <TextBlock Text="{Binding Translation.LootComparatorSlotsColorsDescriptionBlue, FallbackValue=LootComparatorSlotsColorsDescriptionBlue}" Foreground="{StaticResource SolidColorBrush.Text.1}"
                           FontSize="16" TextWrapping="Wrap" Width="auto" Margin="0,0,0,20" />

                <Image Margin="0,0,0,0" Source="../Assets/loot_cpmparator_slot_red.png" Height="50" Width="50" HorizontalAlignment="Left" />
                <TextBlock Text="{Binding Translation.LootComparatorSlotsColorsDescriptionRed, FallbackValue=LootComparatorSlotsColorsDescriptionRed}" Foreground="{StaticResource SolidColorBrush.Text.1}"
                           FontSize="16" TextWrapping="Wrap" Width="auto" Margin="0,0,0,20" />

                <TextBlock Style="{StaticResource InfoDescription.Header}" Text="{Binding Translation.LootComparatorHeaderLootLogFiles, FallbackValue=LOOT_LOG_FILES}" />
                <TextBlock Text="{Binding Translation.LootComparatorDescription8, FallbackValue=Description8}" Foreground="{StaticResource SolidColorBrush.Text.1}"
                           FontSize="16" TextWrapping="Wrap" Width="auto" Margin="0,0,0,20" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
