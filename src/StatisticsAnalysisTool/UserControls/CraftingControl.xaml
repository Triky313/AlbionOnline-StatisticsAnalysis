                                               VerticalAlignment="Top"
                                               TextWrapping="Wrap"
                                               MouseLeftButtonUp="CopyTextBlockTextToClipboard_OnMouseLeftButtonUp" />
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel Orientation="Horizontal" MinWidth="80">
                                            <TextBlock Text="{Binding CraftingBindings.TranslationEmpty, Mode=OneWay, FallbackValue=EMPTY}" 
                                                       Foreground="{StaticResource SolidColorBrush.Accent.Blue.1}" />
                                            <TextBlock Text=": " Foreground="{StaticResource SolidColorBrush.Accent.Blue.1}" />
                                            <TextBlock Text="{Binding CraftingBindings.Journal.RequiredEmptyJournals, Mode=OneWay, FallbackValue=0}" 
                                                       Foreground="{StaticResource SolidColorBrush.Accent.Yellow.3}" FontWeight="Bold" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" MinWidth="80">
                                            <TextBlock Text="{Binding CraftingBindings.TranslationFull, Mode=OneWay, FallbackValue=FULL}" 
                                                       Foreground="{StaticResource SolidColorBrush.Accent.Blue.1}" />
                                            <TextBlock Text=": " Foreground="{StaticResource SolidColorBrush.Accent.Blue.1}" />
                                            <TextBlock Text="{Binding CraftingBindings.Journal.ExpectedFullJournals, Mode=OneWay, FallbackValue=0}" 
                                                       Foreground="{StaticResource SolidColorBrush.Text.1}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" MinWidth="120">
                                            <TextBlock Text="{Binding CraftingBindings.TranslationPartial, Mode=OneWay, FallbackValue=PARTIAL}" 
                                                       Foreground="{StaticResource SolidColorBrush.Accent.Blue.1}" />
                                            <TextBlock Text=": " Foreground="{StaticResource SolidColorBrush.Accent.Blue.1}" />
                                            <TextBlock Text="{Binding CraftingBindings.Journal.PartialJournalPercent, Mode=OneWay, StringFormat={}{0:N2}%, FallbackValue=0.00%}" 
                                                       Foreground="{StaticResource SolidColorBrush.Text.1}" />
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding CraftingBindings.TranslationEmptyPrice, FallbackValue=EMPTY_PRICE}" Foreground="{StaticResource SolidColorBrush.Text.1}" 
                                           MinWidth="80" VerticalAlignment="Center" />
                                <Grid MinWidth="120">
                                    <TextBox x:Name="EmptyJournalPriceTextBox" HorizontalAlignment="Left"
                                             Text="{Binding CraftingBindings.Journal.EmptyJournalPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
