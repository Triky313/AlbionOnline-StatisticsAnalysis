                                </GridViewColumn>
                                <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationExpectedReturn}" Width="115">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource {x:Type GridViewColumnHeader}}">
                                            <Setter Property="ToolTip" Value="{x:Static crafting:CraftingBindings.TranslationResourceExpectedReturnColumnTooltip}" />
                                        </Style>
