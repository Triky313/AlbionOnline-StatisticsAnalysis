<UserControl x:Class="StatisticsAnalysisTool.UserControls.CraftingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewModels="clr-namespace:StatisticsAnalysisTool.ViewModels"
             xmlns:common="clr-namespace:StatisticsAnalysisTool.Common"
             mc:Ignorable="d"
             d:DesignHeight="900"
             d:DesignWidth="1200"
             d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="340" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="0" Grid.ColumnSpan="2" Height="29" Margin="0,0,0,8" Panel.ZIndex="20">
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="CraftingItemSearchTextBox" Text="{Binding CraftingBindings.ItemSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="360" Height="24" Margin="0,0,5,0" TextWrapping="NoWrap" />
                        <ComboBox ItemsSource="{Binding CraftingBindings.ItemTiers}"
                                  SelectedValue="{Binding CraftingBindings.SelectedItemTier, Mode=TwoWay}"
                                  SelectedValuePath="Key"
                                  DisplayMemberPath="Value"
                                  HorizontalAlignment="Left"
                                  Margin="5,0"
                                  Width="85"
                                  Height="24" />
                        <ComboBox ItemsSource="{Binding CraftingBindings.ItemLevels}"
                                  SelectedValue="{Binding CraftingBindings.SelectedItemLevel, Mode=TwoWay}"
                                  SelectedValuePath="Key"
                                  DisplayMemberPath="Value"
                                  HorizontalAlignment="Left"
                                  Margin="5,0"
                                  Width="85"
                                  Height="24" />
                    </StackPanel>
                    <Popup PlacementTarget="{Binding ElementName=CraftingItemSearchTextBox}" Placement="Bottom"
                           IsOpen="{Binding CraftingBindings.IsItemSearchPopupOpen, Mode=TwoWay}" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">
                            <Border DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type Popup}}}"
                                    Background="{StaticResource SolidColorBrush.Background.2}" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}"
                                    BorderThickness="1" Width="420" MaxHeight="520">
                                <ListBox SelectionMode="Single"
                                         SelectionChanged="ListBoxItemSearch_OnSelectionChanged"
                                         ItemsSource="{Binding CraftingBindings.ListBoxItemSearchItems}"
                                         Width="420"
                                         MinHeight="38"
                                         MaxHeight="520"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding Icon}" Width="28" Height="28" Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource SolidColorBrush.Text.1}" VerticalAlignment="Center" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Width="370" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Popup>
                </Grid>

                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="Crafting" Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Number of runs" Foreground="{StaticResource SolidColorBrush.Text.2}" Width="105" VerticalAlignment="Center" />
                        <TextBox Text="{Binding CraftingBindings.CraftingRuns, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90" Height="24" common:TextBoxHelper.OnlyNumeric="Natural" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Focus" Foreground="{StaticResource SolidColorBrush.Text.2}" Width="105" VerticalAlignment="Center" />
                        <CheckBox IsChecked="{Binding CraftingBindings.UsesFocus, Mode=TwoWay}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Return rate %" Foreground="{StaticResource SolidColorBrush.Text.2}" Width="105" VerticalAlignment="Center" />
                        <TextBox Text="{Binding CraftingBindings.ReturnRatePercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90" Height="24" common:TextBoxHelper.OnlyNumeric="Double" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Context" Foreground="{StaticResource SolidColorBrush.Text.2}" Width="105" VerticalAlignment="Center" />
                        <ComboBox ItemsSource="{Binding CraftingBindings.MarketLocations}"
                                  SelectedValue="{Binding CraftingBindings.SelectedMarketLocation, Mode=TwoWay}"
                                  SelectedValuePath="Key"
                                  DisplayMemberPath="Value"
                                  Width="180"
                                  Height="24" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Station fee" Foreground="{StaticResource SolidColorBrush.Text.2}" Width="105" VerticalAlignment="Center" />
                        <TextBox Text="{Binding CraftingBindings.StationFee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90" Height="24" common:TextBoxHelper.OnlyNumeric="Double" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Sales tax %" Foreground="{StaticResource SolidColorBrush.Text.2}" Width="105" VerticalAlignment="Center" />
                        <TextBox Text="{Binding CraftingBindings.SalesTaxPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90" Height="24" common:TextBoxHelper.OnlyNumeric="Double" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="Other costs" Foreground="{StaticResource SolidColorBrush.Text.2}" Width="105" VerticalAlignment="Center" />
                        <TextBox Text="{Binding CraftingBindings.OtherCosts, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90" Height="24" common:TextBoxHelper.OnlyNumeric="Double" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Sell price" Foreground="{StaticResource SolidColorBrush.Text.2}" Width="105" VerticalAlignment="Center" />
                        <TextBox Text="{Binding CraftingBindings.OutputUnitPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90" Height="24" common:TextBoxHelper.OnlyNumeric="Double" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="New" Width="58" Height="24" Command="{Binding CraftingBindings.NewCommand}" />
                        <Button Content="Save" Width="58" Height="24" Margin="5,0,0,0" Command="{Binding CraftingBindings.SaveCommand}" />
                        <Button Content="Delete" Width="58" Height="24" Margin="5,0,0,0" Command="{Binding CraftingBindings.DeleteCommand}" />
                        <Button Content="Reset" Width="58" Height="24" Margin="5,0,0,0" Command="{Binding CraftingBindings.ResetCommand}" />
                        <Button Content="Prices" Width="58" Height="24" Margin="5,0,0,0" Command="{Binding CraftingBindings.LoadPricesCommand}" />
                    </StackPanel>

                    <TextBlock Text="{Binding CraftingBindings.StatusText}" Foreground="{StaticResource SolidColorBrush.Text.3}" TextWrapping="Wrap" />

                    <TextBlock Text="Result" Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" FontSize="16" FontWeight="SemiBold" Margin="0,14,0,8" />
                    <UniformGrid Columns="1">
                        <TextBlock Text="{Binding CraftingBindings.Calculation.OutputQuantity, StringFormat=Output: {0}, FallbackValue=OUTPUT_QUANTITY}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                        <TextBlock Text="{Binding CraftingBindings.Calculation.GrossMaterialCosts, StringFormat=Gross materials: {0:N2}, FallbackValue=GROSS_MATERIAL_COSTS}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                        <TextBlock Text="{Binding CraftingBindings.Calculation.NetMaterialCosts, StringFormat=Net materials: {0:N2}, FallbackValue=NET_MATERIAL_COSTS}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                        <TextBlock Text="{Binding CraftingBindings.Calculation.NonReturnableMaterialCosts, StringFormat=Non-returnable: {0:N2}, FallbackValue=NON_RETURNABLE_MATERIAL_COSTS}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                        <TextBlock Text="{Binding CraftingBindings.Calculation.StationFee, StringFormat=Station: {0:N2}, FallbackValue=STATION_FEE}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                        <TextBlock Text="{Binding CraftingBindings.Calculation.JournalCosts, StringFormat=Journal costs: {0:N2}, FallbackValue=JOURNAL_COSTS}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                        <TextBlock Text="{Binding CraftingBindings.Calculation.JournalRevenue, StringFormat=Journal revenue: {0:N2}, FallbackValue=JOURNAL_REVENUE}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                        <TextBlock Text="{Binding CraftingBindings.Calculation.SalesRevenueNet, StringFormat=Sales net: {0:N2}, FallbackValue=SALES_REVENUE_NET}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                        <TextBlock Text="{Binding CraftingBindings.Calculation.Profit, StringFormat=Profit: {0:N2}, FallbackValue=PROFIT}" Foreground="{StaticResource SolidColorBrush.Text.1}" FontWeight="Bold" />
                        <TextBlock Text="{Binding CraftingBindings.Calculation.RoiPercent, StringFormat=ROI: {0:N2}%, FallbackValue=ROI_PERCENT}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                        <TextBlock Text="{Binding CraftingBindings.Calculation.BreakEvenPrice, StringFormat=Break-even: {0:N2}, FallbackValue=BREAK_EVEN_PRICE}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                        <TextBlock Text="{Binding CraftingBindings.Calculation.ProfitPerItem, StringFormat=Profit/item: {0:N2}, FallbackValue=PROFIT_PER_ITEM}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                        <TextBlock Text="{Binding CraftingBindings.Calculation.WeightBeforeCrafting, StringFormat=Weight before: {0:N2}, FallbackValue=WEIGHT_BEFORE_CRAFTING}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                        <TextBlock Text="{Binding CraftingBindings.Calculation.WeightAfterCrafting, StringFormat=Weight after: {0:N2}, FallbackValue=WEIGHT_AFTER_CRAFTING}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                    </UniformGrid>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical" Margin="10,0">
                    <TextBlock Text="Resources" Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ListView ItemsSource="{Binding CraftingBindings.Resources}" Height="260" MinWidth="620">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Icon" Width="45">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding Icon}" Width="32" Height="32" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Resource" Width="210" DisplayMemberBinding="{Binding DisplayName}" />
                                <GridViewColumn Header="Type" Width="85" DisplayMemberBinding="{Binding ResourceKindText}" />
                                <GridViewColumn Header="Gross" Width="80" DisplayMemberBinding="{Binding GrossQuantity}" />
                                <GridViewColumn Header="Expected return" Width="105" DisplayMemberBinding="{Binding ExpectedReturnQuantity}" />
                                <GridViewColumn Header="Net" Width="80" DisplayMemberBinding="{Binding NetQuantity}" />
                                <GridViewColumn Header="Price" Width="90">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding UnitPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="78" Height="22" common:TextBoxHelper.OnlyNumeric="Double" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Net cost" Width="90" DisplayMemberBinding="{Binding NetCost}" />
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Grid Margin="0,12,0,0">
                        <Grid.Style>
                            <Style TargetType="{x:Type Grid}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CraftingBindings.HasJournal}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock Text="Journals" Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{Binding CraftingBindings.Journal.Icon}" Width="36" Height="36" />
                                <TextBlock Text="{Binding CraftingBindings.Journal.DisplayName}" Foreground="{StaticResource SolidColorBrush.Text.1}" VerticalAlignment="Center" Margin="8,0,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="Empty price" Foreground="{StaticResource SolidColorBrush.Text.2}" Width="95" VerticalAlignment="Center" />
                                <TextBox Text="{Binding CraftingBindings.Journal.EmptyJournalPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90" Height="22" common:TextBoxHelper.OnlyNumeric="Double" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Full price" Foreground="{StaticResource SolidColorBrush.Text.2}" Width="95" VerticalAlignment="Center" />
                                <TextBox Text="{Binding CraftingBindings.Journal.FullJournalPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90" Height="22" common:TextBoxHelper.OnlyNumeric="Double" />
                            </StackPanel>
                        </StackPanel>

                        <UniformGrid Grid.Column="1" Columns="3" Rows="2" Margin="10,26,0,0">
                            <TextBlock Text="{Binding CraftingBindings.Journal.RequiredEmptyJournals, StringFormat=Empty: {0}}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                            <TextBlock Text="{Binding CraftingBindings.Journal.ExpectedFullJournals, StringFormat=Full: {0}}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                            <TextBlock Text="{Binding CraftingBindings.Journal.PartialJournalPercent, StringFormat=Partial: {0:N2}%}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                            <TextBlock Text="{Binding CraftingBindings.Journal.TotalEmptyJournalCosts, StringFormat=Costs: {0:N2}}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                            <TextBlock Text="{Binding CraftingBindings.Journal.TotalFullJournalRevenue, StringFormat=Revenue: {0:N2}}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                        </UniformGrid>
                    </Grid>

                    <TextBlock Text="Notes" Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" FontSize="16" FontWeight="SemiBold" Margin="0,12,0,4" />
                    <TextBox Text="{Binding CraftingBindings.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="85" MinWidth="620" TextWrapping="Wrap" AcceptsReturn="True" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <GridSplitter Grid.Row="1" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" HorizontalAlignment="Stretch" Background="{StaticResource SolidColorBrush.Accent.Blue.4}" />

        <Grid Grid.Row="2" Margin="10,5,10,10">
            <TextBlock Text="Saved craftings" Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
            <ListView ItemsSource="{Binding CraftingBindings.SavedCraftings}"
                      SelectedItem="{Binding CraftingBindings.SelectedSavedCrafting, Mode=TwoWay}"
                      SelectionChanged="SavedCraftings_OnSelectionChanged"
                      Margin="0,28,0,0">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Icon" Width="45">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding Icon}" Width="32" Height="32" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Item" Width="260" DisplayMemberBinding="{Binding ItemName}" />
                        <GridViewColumn Header="Details" Width="260" DisplayMemberBinding="{Binding Summary}" />
                        <GridViewColumn Header="Main costs" Width="110" DisplayMemberBinding="{Binding NetMaterialCosts}" />
                        <GridViewColumn Header="Profit" Width="110" DisplayMemberBinding="{Binding Profit}" />
                        <GridViewColumn Header="Changed" Width="170" DisplayMemberBinding="{Binding LastChangedUtc}" />
                        <GridViewColumn Header="Notes" Width="360" DisplayMemberBinding="{Binding Notes}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
</UserControl>
