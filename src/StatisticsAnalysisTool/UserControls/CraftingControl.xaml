                                        <TextBlock Text="{Binding CraftingBindings.TranslationTotalCosts, FallbackValue=TOTAL_COSTS}" Style="{StaticResource CraftingResultLabel}" />
                                        <TextBlock Text="{Binding CraftingBindings.Calculation.TotalCosts, StringFormat={}{0:N0}, FallbackValue=0}" Style="{StaticResource CraftingResultCostValue}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CraftingResultTile}" ToolTip="{Binding CraftingBindings.TranslationSalesNetTooltip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CraftingBindings.TranslationSalesNet, FallbackValue=SALES_NET}" Style="{StaticResource CraftingResultLabel}" />
                                        <TextBlock Text="{Binding CraftingBindings.Calculation.SalesRevenueNet, StringFormat={}{0:N0}, FallbackValue=0}" Style="{StaticResource CraftingResultRevenueValue}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CraftingResultTile}" ToolTip="{Binding CraftingBindings.TranslationProfitTooltip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CraftingBindings.TranslationProfit, FallbackValue=PROFIT}" Style="{StaticResource CraftingResultLabel}" />
                                        <TextBlock Text="{Binding CraftingBindings.Calculation.Profit, StringFormat={}{0:N0}, FallbackValue=0}" Style="{StaticResource CraftingResultProfitValue}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CraftingResultTile}" ToolTip="{Binding CraftingBindings.TranslationProfitPerItemTooltip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CraftingBindings.TranslationProfitPerItem, FallbackValue=PROFIT_PER_ITEM}" Style="{StaticResource CraftingResultLabel}" />
                                        <TextBlock Text="{Binding CraftingBindings.Calculation.ProfitPerItem, StringFormat={}{0:N0}, FallbackValue=0}" Style="{StaticResource CraftingResultProfitPerItemValue}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CraftingResultTile}" ToolTip="{Binding CraftingBindings.TranslationRoiTooltip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CraftingBindings.TranslationRoi, FallbackValue=ROI}" Style="{StaticResource CraftingResultLabel}" />
                                        <TextBlock Text="{Binding CraftingBindings.Calculation.RoiPercent, StringFormat={}{0:N2}%, FallbackValue=0.00%}" Style="{StaticResource CraftingResultRoiValue}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CraftingResultTile}" ToolTip="{Binding CraftingBindings.TranslationBreakEvenTooltip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CraftingBindings.TranslationBreakEven, FallbackValue=BREAK_EVEN}" Style="{StaticResource CraftingResultLabel}" />
                                        <TextBlock Text="{Binding CraftingBindings.Calculation.BreakEvenPrice, StringFormat={}{0:N0}, FallbackValue=0}" Style="{StaticResource CraftingResultBreakEvenValue}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <Border Style="{StaticResource CraftingResultTile}" ToolTip="{Binding CraftingBindings.TranslationGrossMaterialsTooltip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CraftingBindings.TranslationGrossMaterials, FallbackValue=GROSS_MATERIALS}" Style="{StaticResource CraftingResultLabel}" />
                                        <TextBlock Text="{Binding CraftingBindings.Calculation.GrossMaterialCosts, StringFormat={}{0:N0}, FallbackValue=0}" Style="{StaticResource CraftingResultCostValue}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CraftingResultTile}" ToolTip="{Binding CraftingBindings.TranslationNetMaterialsTooltip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CraftingBindings.TranslationNetMaterials, FallbackValue=NET_MATERIALS}" Style="{StaticResource CraftingResultLabel}" />
                                        <TextBlock Text="{Binding CraftingBindings.Calculation.NetMaterialCosts, StringFormat={}{0:N0}, FallbackValue=0}" Style="{StaticResource CraftingResultCostValue}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CraftingResultTile}" ToolTip="{Binding CraftingBindings.TranslationNonReturnableTooltip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CraftingBindings.TranslationNonReturnable, FallbackValue=NON_RETURNABLE}" Style="{StaticResource CraftingResultLabel}" />
                                        <TextBlock Text="{Binding CraftingBindings.Calculation.NonReturnableMaterialCosts, StringFormat={}{0:N0}, FallbackValue=0}" Style="{StaticResource CraftingResultCostValue}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CraftingResultTile}" ToolTip="{Binding CraftingBindings.TranslationStationTooltip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CraftingBindings.TranslationStation, FallbackValue=STATION}" Style="{StaticResource CraftingResultLabel}" />
                                        <TextBlock Text="{Binding CraftingBindings.Calculation.StationFee, StringFormat={}{0:N0}, FallbackValue=0}" Style="{StaticResource CraftingResultCostValue}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CraftingResultTile}" ToolTip="{Binding CraftingBindings.TranslationOtherCostsTooltip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CraftingBindings.TranslationOtherCosts, FallbackValue=OTHER_COSTS}" Style="{StaticResource CraftingResultLabel}" />
                                        <TextBlock Text="{Binding CraftingBindings.Calculation.OtherCosts, StringFormat={}{0:N0}, FallbackValue=0}" Style="{StaticResource CraftingResultCostValue}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CraftingResultTile}" ToolTip="{Binding CraftingBindings.TranslationJournalCostsTooltip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CraftingBindings.TranslationJournalCosts, FallbackValue=JOURNAL_COSTS}" Style="{StaticResource CraftingResultLabel}" />
                                        <TextBlock Text="{Binding CraftingBindings.Calculation.JournalCosts, StringFormat={}{0:N0}, FallbackValue=0}" Style="{StaticResource CraftingResultCostValue}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CraftingResultTile}" ToolTip="{Binding CraftingBindings.TranslationJournalRevenueTooltip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CraftingBindings.TranslationJournalRevenue, FallbackValue=JOURNAL_REVENUE}" Style="{StaticResource CraftingResultLabel}" />
                                        <TextBlock Text="{Binding CraftingBindings.Calculation.JournalRevenue, StringFormat={}{0:N0}, FallbackValue=0}" Style="{StaticResource CraftingResultRevenueValue}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <Border Style="{StaticResource CraftingResultTile}" ToolTip="{Binding CraftingBindings.TranslationSalesGrossTooltip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CraftingBindings.TranslationSalesGross, FallbackValue=SALES_GROSS}" Style="{StaticResource CraftingResultLabel}" />
                                        <TextBlock Text="{Binding CraftingBindings.Calculation.SalesRevenueGross, StringFormat={}{0:N0}, FallbackValue=0}" Style="{StaticResource CraftingResultRevenueValue}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CraftingResultTile}" ToolTip="{Binding CraftingBindings.TranslationSalesTaxTooltip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CraftingBindings.TranslationSalesTax, FallbackValue=SALES_TAX}" Style="{StaticResource CraftingResultLabel}" />
                                        <TextBlock Text="{Binding CraftingBindings.Calculation.SalesTax, StringFormat={}{0:N0}, FallbackValue=0}" Style="{StaticResource CraftingResultCostValue}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CraftingResultTile}" ToolTip="{Binding CraftingBindings.TranslationSetupFeeTooltip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CraftingBindings.TranslationSetupFee, FallbackValue=SETUP_FEE}" Style="{StaticResource CraftingResultLabel}" />
                                        <TextBlock Text="{Binding CraftingBindings.Calculation.SetupFee, StringFormat={}{0:N0}, FallbackValue=0}" Style="{StaticResource CraftingResultCostValue}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CraftingResultTile}" ToolTip="{Binding CraftingBindings.TranslationWeightBeforeTooltip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CraftingBindings.TranslationWeightBefore, FallbackValue=WEIGHT_BEFORE}" Style="{StaticResource CraftingResultLabel}" />
                                        <TextBlock Text="{Binding CraftingBindings.Calculation.WeightBeforeCrafting, StringFormat={}{0:N2}, FallbackValue=0.00}" Style="{StaticResource CraftingResultValue}" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CraftingResultTile}" ToolTip="{Binding CraftingBindings.TranslationWeightAfterTooltip}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CraftingBindings.TranslationWeightAfter, FallbackValue=WEIGHT_AFTER}" Style="{StaticResource CraftingResultLabel}" />
                                        <TextBlock Text="{Binding CraftingBindings.Calculation.WeightAfterCrafting, StringFormat={}{0:N2}, FallbackValue=0.00}" Style="{StaticResource CraftingResultValue}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </WrapPanel>
                </Grid>
            </Grid>
        </ScrollViewer>

        <GridSplitter Grid.Row="1" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" HorizontalAlignment="Stretch" Background="{StaticResource SolidColorBrush.Accent.Blue.4}" />

        <Grid Grid.Row="2" Margin="10,5,10,10">
            <TextBlock Text="{Binding CraftingBindings.TranslationSavedCraftings, FallbackValue=SAVED_CRAFTINGS}" Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
            <ListView ItemsSource="{Binding CraftingBindings.SavedCraftings}"
                      SelectedItem="{Binding CraftingBindings.SelectedSavedCrafting, Mode=TwoWay}"
                      SelectionChanged="SavedCraftings_OnSelectionChanged"
                      Margin="0,28,0,0"
                      ItemContainerStyle="{StaticResource SavedCraftingListViewItem}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationIcon}" Width="65">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Image Source="{Binding Icon}" Width="50" Height="50" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationItem}" Width="260">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ItemName}" Style="{StaticResource SavedCraftingCellText}" MaxHeight="40" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationDetails}" Width="300">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Summary}" Style="{StaticResource SavedCraftingCellText}" MaxHeight="40" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationFocus}" Width="70">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <fa5:ImageAwesome Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <fa5:ImageAwesome.Style>
                                            <Style TargetType="{x:Type fa5:ImageAwesome}">
                                                <Setter Property="Icon" Value="Solid_Times" />
                                                <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Red.4}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UsesFocus}" Value="True">
                                                        <Setter Property="Icon" Value="Solid_Check" />
                                                        <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Green.4}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </fa5:ImageAwesome.Style>
                                    </fa5:ImageAwesome>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationTotalCosts}" Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding TotalCosts, StringFormat={}{0:N0}}" Style="{StaticResource SavedCraftingCostText}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationProfit}" Width="110">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Profit, StringFormat={}{0:N0}}" Style="{StaticResource SavedCraftingProfitText}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationProfitPerItem}" Width="125">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding ProfitPerItem, StringFormat={}{0:N0}}" Style="{StaticResource SavedCraftingProfitPerItemText}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationRoi}" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding RoiPercent, StringFormat={}{0:N2}%}" Style="{StaticResource SavedCraftingRoiText}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationBreakEven}" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding BreakEvenPrice, StringFormat={}{0:N0}}" Style="{StaticResource SavedCraftingBreakEvenText}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationChanged}" Width="150" DisplayMemberBinding="{Binding LastChangedUtc}" />
                        <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationNotes}" Width="300">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Notes}" Style="{StaticResource SavedCraftingCellText}" MaxHeight="40" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
        </TabItem>
        <TabItem Header="{x:Static crafting:CraftingBindings.TranslationBlackMarket}"
                 Visibility="{Binding CraftingBindings.BlackMarketTabVisibility}">
            <Grid DataContext="{Binding CraftingBindings.BlackMarket}" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="5" />
                    <RowDefinition Height="{Binding GridSplitterPosition, Mode=TwoWay, FallbackValue=*}" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <StackPanel Orientation="Vertical">
                            <Grid>
                                <TextBox Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ItemSearchTextBoxStyle}" />

                                <Grid Width="24" Height="22" Margin="235,10,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <fa5:ImageAwesome Icon="Solid_Redo" Foreground="{StaticResource SolidColorBrush.Text.1}" MouseUp="FilterReset_MouseUp" />
                                </Grid>
                            </Grid>
                            <StackPanel Orientation="Horizontal">
                                <ComboBox ItemsSource="{Binding ItemShopCategories}"
                                          SelectedItem="{Binding SelectedItemShopCategory, Mode=TwoWay}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="DisplayName"
                                          HorizontalAlignment="Left"
                                          Margin="10,5,5,5"
                                          VerticalAlignment="Top"
                                          Width="150" />
                                <ComboBox ItemsSource="{Binding ItemSubCategories1}"
                                          SelectedItem="{Binding SelectedItemShopSubCategory1, Mode=TwoWay}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="DisplayName"
                                          HorizontalAlignment="Left"
                                          Margin="5,5"
                                          VerticalAlignment="Top"
                                          Width="150" />
                                <ComboBox ItemsSource="{Binding ItemSubCategories2}"
                                          SelectedItem="{Binding SelectedItemShopSubCategory2, Mode=TwoWay}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="DisplayName"
                                          HorizontalAlignment="Left"
                                          Margin="5,5"
                                          VerticalAlignment="Top"
                                          Width="150" />
                                <ComboBox ItemsSource="{Binding ItemSubCategories3}"
                                          SelectedItem="{Binding SelectedItemShopSubCategory3, Mode=TwoWay}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="DisplayName"
                                          HorizontalAlignment="Left"
                                          Margin="5,5"
                                          VerticalAlignment="Top"
                                          Width="150" />
                                <ComboBox ItemsSource="{Binding ItemTiers}"
                                          SelectedValue="{Binding SelectedItemTier, Mode=TwoWay}"
                                          SelectedValuePath="Key"
                                          DisplayMemberPath="Value"
                                          HorizontalAlignment="Left"
                                          Margin="5,5"
                                          MinWidth="70" />
                                <ComboBox ItemsSource="{Binding ItemLevels}"
                                          SelectedValue="{Binding SelectedItemLevel, Mode=TwoWay}"
                                          SelectedValuePath="Key"
                                          DisplayMemberPath="Value"
                                          HorizontalAlignment="Left"
                                          Margin="5,5"
                                          MinWidth="70" />
                                <ComboBox ItemsSource="{Binding ItemQualities}"
                                          SelectedValue="{Binding SelectedQualityLevel, Mode=TwoWay}"
                                          SelectedValuePath="Key"
                                          DisplayMemberPath="Value"
                                          HorizontalAlignment="Left"
                                          Margin="5,5"
                                          MinWidth="120" />
                            </StackPanel>
                            <DockPanel Margin="10,0,0,5">
                                <TextBlock Text="{Binding MarketStatusText}" Foreground="{StaticResource SolidColorBrush.Text.3}" />
                                <TextBlock Text="{Binding ItemCounterText}" Foreground="{StaticResource SolidColorBrush.Text.3}" HorizontalAlignment="Right" DockPanel.Dock="Right" />
                            </DockPanel>
                        </StackPanel>
                    </Grid>

                    <ListView Grid.Row="1"
                              ItemsSource="{Binding ItemsView}"
                              SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                              ScrollViewer.CanContentScroll="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              SelectionMode="Single">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationIcon}" Width="65">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding Icon, IsAsync=True}" Width="50" Height="50" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationItem}" Width="330">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ItemName}" Style="{StaticResource SavedCraftingCellText}" MaxHeight="42" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationTier}" Width="70">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding TierText}" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Text.1}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Tier}" Value="1">
                                                                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Item.Tier.Color.1}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Tier}" Value="2">
                                                                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Item.Tier.Color.2}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Tier}" Value="3">
                                                                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Item.Tier.Color.3}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Tier}" Value="4">
                                                                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Item.Tier.Color.4}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Tier}" Value="5">
                                                                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Item.Tier.Color.5}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Tier}" Value="6">
                                                                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Item.Tier.Color.6}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Tier}" Value="7">
                                                                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Item.Tier.Color.7}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Tier}" Value="8">
                                                                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Item.Tier.Color.8}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="." FontWeight="Bold" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                                                <TextBlock Text="{Binding EnchantmentLevelText}" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Text.1}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding EnchantmentLevel}" Value="0">
                                                                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Item.Level.Color.0}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding EnchantmentLevel}" Value="1">
                                                                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Item.Level.Color.1}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding EnchantmentLevel}" Value="2">
                                                                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Item.Level.Color.2}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding EnchantmentLevel}" Value="3">
                                                                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Item.Level.Color.3}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding EnchantmentLevel}" Value="4">
                                                                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Item.Level.Color.4}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{x:Static crafting:BlackMarketBindings.TranslationQuality}" Width="120" DisplayMemberBinding="{Binding QualityName}" />
                                <GridViewColumn Header="{x:Static crafting:BlackMarketBindings.TranslationCurrentBuyPrice}" Width="130">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding CurrentBuyPrice, StringFormat={}{0:N0}}" Style="{StaticResource SavedCraftingCellText}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{x:Static crafting:BlackMarketBindings.TranslationAverageBoughtPrice}" Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding LatestAveragePrice, StringFormat={}{0:N0}}" Style="{StaticResource SavedCraftingCellText}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{x:Static crafting:BlackMarketBindings.TranslationBoughtLast30Days}" Width="140">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SoldLast30Days, StringFormat={}{0:N0}}" Style="{StaticResource SavedCraftingCellText}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{x:Static crafting:BlackMarketBindings.TranslationBoughtLast365Days}" Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SoldLast365Days, StringFormat={}{0:N0}}" Style="{StaticResource SavedCraftingCellText}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationChanged}" Width="135" DisplayMemberBinding="{Binding LastUpdatedText}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>

                <GridSplitter Grid.Row="1"
                              ResizeDirection="Rows"
                              ResizeBehavior="PreviousAndNext"
                              HorizontalAlignment="Stretch"
                              Background="{StaticResource SolidColorBrush.Accent.Blue.4}" />

                <Grid Grid.Row="2" Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="True">
                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top"
                                    Margin="12,0,0,0">
                            <TextBlock Text="{x:Static crafting:BlackMarketBindings.TranslationChartRange}"
                                       Foreground="{StaticResource SolidColorBrush.Text.2}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            <ComboBox ItemsSource="{Binding ChartDayFilters}"
                                      DisplayMemberPath="Value"
                                      SelectedValuePath="Key"
                                      SelectedValue="{Binding SelectedChartDays, Mode=TwoWay}"
                                      MinWidth="96"
                                      Height="24" />
                        </StackPanel>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{Binding SelectedItemTitle, FallbackValue=BLACK_MARKET}"
                                       Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <TextBlock Text="{x:Static crafting:BlackMarketBindings.TranslationCurrentBuyPrice}" Foreground="{StaticResource SolidColorBrush.Text.2}" />
                                <TextBlock Text=": " Foreground="{StaticResource SolidColorBrush.Text.2}" />
                                <TextBlock Text="{Binding SelectedItem.CurrentBuyPrice, StringFormat={}{0:N0}, FallbackValue=0}" Foreground="{StaticResource SolidColorBrush.Accent.Green.2}" Margin="0,0,12,0" />
                                <TextBlock Text="{x:Static crafting:BlackMarketBindings.TranslationAverageBoughtPrice}" Foreground="{StaticResource SolidColorBrush.Text.2}" />
                                <TextBlock Text=": " Foreground="{StaticResource SolidColorBrush.Text.2}" />
                                <TextBlock Text="{Binding SelectedItem.LatestAveragePrice, StringFormat={}{0:N0}, FallbackValue=0}" Foreground="{StaticResource SolidColorBrush.Text.1}" Margin="0,0,12,0" />
                                <TextBlock Text="{x:Static crafting:BlackMarketBindings.TranslationAverageItemsPerDay}" Foreground="{StaticResource SolidColorBrush.Text.2}" />
                                <TextBlock Text=": " Foreground="{StaticResource SolidColorBrush.Text.2}" />
                                <TextBlock Text="{Binding SelectedItemAverageItemsPerDayText, FallbackValue=0}" Foreground="{StaticResource SolidColorBrush.Text.1}" Margin="0,0,12,0" />
                                <TextBlock Text="{x:Static crafting:BlackMarketBindings.TranslationBoughtLast30Days}" Foreground="{StaticResource SolidColorBrush.Text.2}" />
                                <TextBlock Text=": " Foreground="{StaticResource SolidColorBrush.Text.2}" />
                                <TextBlock Text="{Binding SelectedItem.SoldLast30Days, StringFormat={}{0:N0}, FallbackValue=0}" Foreground="{StaticResource SolidColorBrush.Text.1}" Margin="0,0,12,0" />
                                <TextBlock Text="{x:Static crafting:BlackMarketBindings.TranslationBoughtLast365Days}" Foreground="{StaticResource SolidColorBrush.Text.2}" />
                                <TextBlock Text=": " Foreground="{StaticResource SolidColorBrush.Text.2}" />
                                <TextBlock Text="{Binding SelectedItem.SoldLast365Days, StringFormat={}{0:N0}, FallbackValue=0}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>

                    <wpf:CartesianChart Grid.Row="1"
                                        Series="{Binding ChartSeries}"
                                        XAxes="{Binding ChartXAxes}"
                                        YAxes="{Binding ChartYAxes}"
                                        TooltipPosition="Center"
                                        FindingStrategy="ExactMatchTakeClosest"
                                        LegendPosition="Top"
                                        Background="Transparent"
                                        DrawMarginFrame="{x:Null}" />
                </Grid>
            </Grid>
        </TabItem>
    </TabControl>
</UserControl>
