<UserControl x:Class="StatisticsAnalysisTool.UserControls.CraftingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             xmlns:wpf="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:viewModels="clr-namespace:StatisticsAnalysisTool.ViewModels"
             xmlns:common="clr-namespace:StatisticsAnalysisTool.Common"
             xmlns:crafting="clr-namespace:StatisticsAnalysisTool.Crafting"
             xmlns:enum="clr-namespace:StatisticsAnalysisTool.Enumerations"
             mc:Ignorable="d"
             d:DesignHeight="1100"
             d:DesignWidth="1300"
             d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel}">
    <UserControl.Resources>
        <Style x:Key="CraftingResultTile" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource SolidColorBrush.Background.2}" />
            <Setter Property="BorderBrush" Value="{StaticResource SolidColorBrush.Background.4}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="1" />
            <Setter Property="Height" Value="55" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Padding" Value="5,5" />
            <Setter Property="Margin" Value="0,0,5,0" />
        </Style>
        <Style x:Key="CraftingEditorLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Text.2}" />
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="MaxWidth" Value="250" />
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <Style x:Key="CraftingResultLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Text.4}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="CraftingResultValue" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Text.1}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,2,0,0" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="CraftingResultCostValue" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CraftingResultValue}">
            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Red.2}" />
        </Style>
        <Style x:Key="CraftingResultRevenueValue" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CraftingResultValue}">
            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Green.2}" />
        </Style>
        <Style x:Key="CraftingResultInfoValue" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CraftingResultValue}">
            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Blue.2}" />
        </Style>
        <Style x:Key="CraftingResultBreakEvenValue" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CraftingResultValue}">
            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Yellow.1}" />
        </Style>
        <Style x:Key="CraftingResultProfitValue" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CraftingResultValue}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding CraftingBindings.Calculation.IsProfitPositive}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Green.2}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CraftingBindings.Calculation.IsProfitNegative}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Red.2}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CraftingResultRoiValue" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CraftingResultValue}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding CraftingBindings.Calculation.IsRoiPositive}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Green.2}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CraftingBindings.Calculation.IsRoiNegative}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Red.2}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CraftingResultProfitPerItemValue" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CraftingResultValue}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding CraftingBindings.Calculation.IsProfitPerItemPositive}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Green.2}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding CraftingBindings.Calculation.IsProfitPerItemNegative}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Red.2}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SavedCraftingCellText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Text.1}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SavedCraftingCostText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource SavedCraftingCellText}">
            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Red.2}" />
        </Style>
        <Style x:Key="SavedCraftingProfitText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource SavedCraftingCellText}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsProfitPositive}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Green.2}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsProfitNegative}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Red.2}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SavedCraftingProfitPerItemText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource SavedCraftingCellText}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsProfitPerItemPositive}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Green.2}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsProfitPerItemNegative}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Red.2}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SavedCraftingRoiText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource SavedCraftingCellText}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRoiPositive}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Green.2}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsRoiNegative}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Red.2}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SavedCraftingBreakEvenText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource SavedCraftingCellText}">
            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Yellow.1}" />
        </Style>
        <Style x:Key="CraftingResourceQuantityText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Text.1}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="CraftingResourceCostText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CraftingResourceQuantityText}">
            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Red.2}" />
        </Style>
        <Style x:Key="CraftingResourceNetQuantityText" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource CraftingResourceQuantityText}">
            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Yellow.3}" />
        </Style>
        <Style x:Key="CraftingSellPriceOptionText" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Text.7}" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding PriceDateStatus}" Value="{x:Static enum:ValueTimeStatus.Normal}">
                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.TimeValue.PastTime.1}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding PriceDateStatus}" Value="{x:Static enum:ValueTimeStatus.ToOldFirst}">
                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.TimeValue.PastTime.3}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding PriceDateStatus}" Value="{x:Static enum:ValueTimeStatus.ToOldSecond}">
                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.TimeValue.PastTime.5}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding PriceDateStatus}" Value="{x:Static enum:ValueTimeStatus.ToOldThird}">
                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.TimeValue.PastTime.7}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding PriceDateStatus}" Value="{x:Static enum:ValueTimeStatus.NoValue}">
                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Text.7}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SavedCraftingListViewItem" TargetType="{x:Type ListViewItem}" BasedOn="{StaticResource {x:Type ListViewItem}}">
            <Setter Property="MinHeight" Value="50" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>
    <TabControl Background="Transparent" BorderThickness="0" PreviewMouseDown="CraftingControl_OnPreviewMouseDown">
        <TabItem Header="{x:Static crafting:CraftingBindings.TranslationItemCrafting}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="5" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="285" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,8" Panel.ZIndex="20">
                    <StackPanel Orientation="Vertical">
                        <StackPanel Width="360" Height="24" Orientation="Horizontal" HorizontalAlignment="Left">
                            <TextBox x:Name="CraftingItemSearchTextBox" Text="{Binding CraftingBindings.ItemSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     GotKeyboardFocus="CraftingItemSearch_OnGotKeyboardFocus"
                                     LostKeyboardFocus="CraftingItemSearch_OnLostKeyboardFocus"
                                     PreviewMouseLeftButtonUp="CraftingItemSearch_OnPreviewMouseLeftButtonUp"
                                     Width="300" Height="24" TextWrapping="NoWrap" />
                            <Grid Width="22" Height="22" Margin="5,1,0,0" HorizontalAlignment="Left">
                                <fa5:ImageAwesome Icon="Solid_Redo" Foreground="{StaticResource SolidColorBrush.Text.1}" MouseUp="CraftingItemFilterReset_MouseUp" />
                            </Grid>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ComboBox ItemsSource="{Binding CraftingBindings.ItemShopCategories}"
                                      SelectedItem="{Binding CraftingBindings.SelectedItemShopCategory, Mode=TwoWay}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="DisplayName"
                                      HorizontalAlignment="Left"
                                      Margin="0,5,5,5"
                                      VerticalAlignment="Top"
                                      Width="150" />
                            <ComboBox ItemsSource="{Binding CraftingBindings.ItemSubCategories1}"
                                      SelectedItem="{Binding CraftingBindings.SelectedItemShopSubCategory1, Mode=TwoWay}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="DisplayName"
                                      HorizontalAlignment="Left"
                                      Margin="5,5"
                                      VerticalAlignment="Top"
                                      Width="150" />
                            <ComboBox ItemsSource="{Binding CraftingBindings.ItemSubCategories2}"
                                      SelectedItem="{Binding CraftingBindings.SelectedItemShopSubCategory2, Mode=TwoWay}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="DisplayName"
                                      HorizontalAlignment="Left"
                                      Margin="5,5"
                                      VerticalAlignment="Top"
                                      Width="150" />
                            <ComboBox ItemsSource="{Binding CraftingBindings.ItemTiers}"
                                      SelectedValue="{Binding CraftingBindings.SelectedItemTier, Mode=TwoWay}"
                                      SelectedValuePath="Key"
                                      DisplayMemberPath="Value"
                                      HorizontalAlignment="Left"
                                      Margin="5,5"
                                      MinWidth="70" />
                            <ComboBox ItemsSource="{Binding CraftingBindings.ItemLevels}"
                                      SelectedValue="{Binding CraftingBindings.SelectedItemLevel, Mode=TwoWay}"
                                      SelectedValuePath="Key"
                                      DisplayMemberPath="Value"
                                      HorizontalAlignment="Left"
                                      Margin="5,5"
                                      MinWidth="70" />
                        </StackPanel>
                    </StackPanel>
                    <Popup PlacementTarget="{Binding ElementName=CraftingItemSearchTextBox}" Placement="Bottom"
                           IsOpen="{Binding CraftingBindings.IsItemSearchPopupOpen, Mode=TwoWay}" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">
                            <Border DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type Popup}}}"
                                    Background="{StaticResource SolidColorBrush.Background.2}" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}"
                                    BorderThickness="1" Width="420" MaxHeight="520">
                                <ListBox x:Name="CraftingItemSearchListBox"
                                         SelectionMode="Single"
                                         SelectionChanged="ListBoxItemSearch_OnSelectionChanged"
                                         ItemsSource="{Binding CraftingBindings.ListBoxItemSearchItems}"
                                         Width="420"
                                         MinHeight="38"
                                         MaxHeight="520"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding Icon}" Width="28" Height="28" Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource SolidColorBrush.Text.1}" VerticalAlignment="Center" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" Width="370" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Popup>
                </Grid>

                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Vertical">
                    <TextBlock Text="{Binding CraftingBindings.TranslationCrafting, FallbackValue=CRAFTING}" Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />

                    <DockPanel LastChildFill="False" Margin="0,0,0,5">
                        <TextBlock Text="{Binding CraftingBindings.TranslationNumberOfRuns, FallbackValue=NUMBER_OF_RUNS}" Style="{StaticResource CraftingEditorLabel}" />
                        <TextBox Text="{Binding CraftingBindings.CraftingRuns, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="90" Height="24" VerticalAlignment="Top" common:TextBoxHelper.OnlyNumeric="Natural" />
                    </DockPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,5">
                        <TextBlock Text="{Binding CraftingBindings.TranslationFocus, FallbackValue=FOCUS}" Style="{StaticResource CraftingEditorLabel}" />
                        <CheckBox IsChecked="{Binding CraftingBindings.UsesFocus, Mode=TwoWay}" VerticalAlignment="Center" />
                    </DockPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,5">
                        <TextBlock Text="{Binding CraftingBindings.TranslationDailyBonusRrr, FallbackValue=DAILY_BONUS_RRR}" Style="{StaticResource CraftingEditorLabel}" />
                        <ComboBox ItemsSource="{Binding CraftingBindings.DailyBonusOptions}"
                                  SelectedItem="{Binding CraftingBindings.SelectedDailyBonus, Mode=TwoWay}"
                                  DisplayMemberPath="Name" Width="90" Height="24" VerticalAlignment="Top" />
                    </DockPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,5">
                        <TextBlock Text="{Binding CraftingBindings.TranslationHideoutBonus, FallbackValue=HIDEOUT_BONUS}" Style="{StaticResource CraftingEditorLabel}" />
                        <ComboBox ItemsSource="{Binding CraftingBindings.HideoutBonusOptions}"
                                  SelectedItem="{Binding CraftingBindings.SelectedHideoutBonus, Mode=TwoWay}"
                                  DisplayMemberPath="Name" Width="180" Height="24" VerticalAlignment="Top" />
                    </DockPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,5" Panel.ZIndex="10">
                        <TextBlock Text="{Binding CraftingBindings.TranslationCraftingLocation, FallbackValue=CRAFTING_LOCATION}" Style="{StaticResource CraftingEditorLabel}" />
                        <Grid>
                            <TextBox x:Name="CraftingLocationSearchTextBox"
                                     Text="{Binding CraftingBindings.CraftingLocationSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     MinWidth="180"
                                     Height="24"
                                     TextWrapping="NoWrap"
                                     GotKeyboardFocus="CraftingLocationSearch_OnGotKeyboardFocus" />
                            <Popup PlacementTarget="{Binding ElementName=CraftingLocationSearchTextBox}"
                                   Placement="Bottom"
                                   IsOpen="{Binding CraftingBindings.IsCraftingLocationPopupOpen, Mode=TwoWay}"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">
                                <Border DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type Popup}}}"
                                        Background="{StaticResource SolidColorBrush.Background.2}"
                                        BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}"
                                        BorderThickness="1"
                                        Width="320"
                                        MaxHeight="520">
                                    <ListBox SelectionMode="Single"
                                             SelectionChanged="ListBoxCraftingLocation_OnSelectionChanged"
                                             ItemsSource="{Binding CraftingBindings.ListBoxCraftingLocationItems}"
                                             Width="320"
                                             MinHeight="38"
                                             MaxHeight="520"
                                             BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Vertical" Margin="2">
                                                    <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource SolidColorBrush.Text.1}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding BonusSummary}" Foreground="{StaticResource SolidColorBrush.Text.3}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>
                    </DockPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,5">
                        <TextBlock Text="{Binding CraftingBindings.SelectedCraftingLocationBonusSummary}" Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}"
                                   MaxWidth="250" Height="34" Margin="0,0,0,5" TextWrapping="Wrap" />
                    </DockPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,5">
                        <TextBlock Text="{Binding CraftingBindings.TranslationReturnRatePercent, FallbackValue=RETURN_RATE_PERCENT}" Style="{StaticResource CraftingEditorLabel}" />
                        <TextBox Text="{Binding CraftingBindings.ReturnRatePercentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90" Height="24" VerticalAlignment="Top" common:TextBoxHelper.OnlyNumeric="Double" />
                    </DockPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,5">
                        <TextBlock Text="{Binding CraftingBindings.TranslationPriceMarket, FallbackValue=PRICE_MARKET}" Style="{StaticResource CraftingEditorLabel}" />
                        <ComboBox ItemsSource="{Binding CraftingBindings.MarketLocations}"
                                  SelectedValue="{Binding CraftingBindings.SelectedMarketLocation, Mode=TwoWay}"
                                  SelectedValuePath="Key" DisplayMemberPath="Value" Width="180" Height="24" VerticalAlignment="Top" />
                    </DockPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,5">
                        <TextBlock Text="{Binding CraftingBindings.TranslationStationFee, FallbackValue=STATION_FEE}" Style="{StaticResource CraftingEditorLabel}" />
                        <TextBox Text="{Binding CraftingBindings.StationFee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90" Height="24" VerticalAlignment="Top" common:TextBoxHelper.OnlyNumeric="Double" />
                    </DockPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,5">
                        <TextBlock Text="{Binding CraftingBindings.TranslationSalesTaxPercent, FallbackValue=SALES_TAX_PERCENT}" Style="{StaticResource CraftingEditorLabel}" />
                        <TextBox Text="{Binding CraftingBindings.SalesTaxPercentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="90" Height="24" VerticalAlignment="Top" common:TextBoxHelper.OnlyNumeric="Double" />
                    </DockPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,5">
                        <TextBlock Text="{Binding CraftingBindings.TranslationSetupFee, FallbackValue=SETUP_FEE}" Style="{StaticResource CraftingEditorLabel}" />
                        <TextBox Text="{Binding CraftingBindings.SetupFeePercentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="90" Height="24" VerticalAlignment="Top" common:TextBoxHelper.OnlyNumeric="Double" />
                    </DockPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,5">
                        <TextBlock Text="{Binding CraftingBindings.TranslationOtherCosts, FallbackValue=OTHER_COSTS}" Style="{StaticResource CraftingEditorLabel}" />
                        <TextBox Text="{Binding CraftingBindings.OtherCosts, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="90" Height="24" VerticalAlignment="Top" common:TextBoxHelper.OnlyNumeric="Double" />
                    </DockPanel>
                    <DockPanel LastChildFill="False" Margin="0,0,0,10">
                        <TextBlock Text="{Binding CraftingBindings.TranslationSellPrice, FallbackValue=SELL_PRICE}" Style="{StaticResource CraftingEditorLabel}" />
                        <Grid>
                            <TextBox x:Name="OutputUnitPriceTextBox"
                                     Text="{Binding CraftingBindings.OutputUnitPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="90"
                                     Height="24"
                                     VerticalAlignment="Top"
                                     common:TextBoxHelper.OnlyNumeric="Double"
                                     GotKeyboardFocus="OutputUnitPrice_OnGotKeyboardFocus"
                                     LostKeyboardFocus="OutputUnitPrice_OnLostKeyboardFocus"
                                     PreviewMouseLeftButtonDown="PriceTextBox_OnPreviewMouseLeftButtonDown"
                                     PreviewMouseLeftButtonUp="OutputUnitPrice_OnPreviewMouseLeftButtonUp" />
                            <Popup PlacementTarget="{Binding ElementName=OutputUnitPriceTextBox}"
                                   Placement="Bottom"
                                   IsOpen="{Binding CraftingBindings.IsSellPricePopupOpen, Mode=TwoWay}"
                                   StaysOpen="False"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">
                                <Border DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type Popup}}}"
                                        Background="{StaticResource SolidColorBrush.Background.2}"
                                        BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}"
                                        BorderThickness="1"
                                        Width="230"
                                        MaxHeight="360">
                                    <ListBox x:Name="SellPriceOptionsListBox"
                                             SelectionMode="Single"
                                             SelectionChanged="ListBoxSellPrice_OnSelectionChanged"
                                             ItemsSource="{Binding CraftingBindings.SellPriceOptions}"
                                             Width="230"
                                             MinHeight="38"
                                             MaxHeight="360"
                                             BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisplayText}" ToolTip="{Binding UpdateDateTimeText}" Style="{StaticResource CraftingSellPriceOptionText}" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="{Binding CraftingBindings.TranslationNew, FallbackValue=NEW}" Width="80" Height="24" Command="{Binding CraftingBindings.NewCommand}" />
                        <Button Content="{Binding CraftingBindings.TranslationSave, FallbackValue=SAVE}" Width="80" Height="24" Margin="5,0,0,0" Command="{Binding CraftingBindings.SaveCommand}" />
                        <Button Content="{Binding CraftingBindings.TranslationDelete, FallbackValue=DELETE}" Width="80" Height="24" Margin="5,0,0,0"
                                Style="{StaticResource Style.Button.Danger}" Command="{Binding CraftingBindings.DeleteCommand}" />
                        <Button Content="{Binding CraftingBindings.TranslationPrices, FallbackValue=PRICES}" Width="80" Height="24" Margin="5,0,0,0" Command="{Binding CraftingBindings.LoadPricesCommand}" />
                    </StackPanel>

                    <TextBlock Text="{Binding CraftingBindings.StatusText}" Foreground="{StaticResource SolidColorBrush.Text.3}" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical" Margin="10,0">
                    <TextBlock Text="{Binding CraftingBindings.TranslationResources, FallbackValue=RESOURCES}" Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ListView ItemsSource="{Binding CraftingBindings.Resources}" MinHeight="150" MinWidth="620">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationIcon}" Width="45">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource {x:Type GridViewColumnHeader}}">
                                            <Setter Property="ToolTip" Value="{x:Static crafting:CraftingBindings.TranslationResourceIconColumnTooltip}" />
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding Icon}" Width="32" Height="32" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationResource}" Width="250">
