                                             PreviewMouseLeftButtonDown="PriceTextBox_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="JournalEmptyPrice_OnPreviewMouseLeftButtonUp" />
                                    <Popup PlacementTarget="{Binding ElementName=EmptyJournalPriceTextBox}"
                                           Placement="Bottom"
                                           IsOpen="{Binding CraftingBindings.Journal.IsEmptyJournalPricePopupOpen, Mode=TwoWay}"
                                           StaysOpen="False"
                                           AllowsTransparency="True"
                                           PopupAnimation="Slide">
                                        <Border DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type Popup}}}"
                                                Background="{StaticResource SolidColorBrush.Background.2}"
                                                BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}"
                                                BorderThickness="1"
                                                Width="230"
                                                MaxHeight="360">
                                            <ListBox SelectionMode="Single"
                                                     SelectionChanged="ListBoxJournalEmptyPrice_OnSelectionChanged"
                                                     ItemsSource="{Binding CraftingBindings.Journal.EmptyJournalPriceOptions}"
                                                     Width="230"
                                                     MinHeight="38"
                                                     MaxHeight="360"
                                                     BorderThickness="0"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding DisplayText}" ToolTip="{Binding UpdateDateTimeText}" Style="{StaticResource CraftingSellPriceOptionText}" />
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" MinWidth="300">
                                    <TextBlock Text="{Binding CraftingBindings.TranslationCosts, Mode=OneWay, FallbackValue=COSTS}" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                                    <TextBlock Text=": " Foreground="{StaticResource SolidColorBrush.Text.1}" />
                                    <TextBlock Text="{Binding CraftingBindings.Journal.TotalEmptyJournalCosts, Mode=OneWay, StringFormat={}{0:N0}, FallbackValue=0}" 
                                               Foreground="{StaticResource SolidColorBrush.Accent.Red.2}" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <TextBlock Text="{Binding CraftingBindings.TranslationFullPrice, FallbackValue=FULL_PRICE}" Foreground="{StaticResource SolidColorBrush.Text.2}" 
                                           VerticalAlignment="Center" MinWidth="80" />
                                <Grid MinWidth="120">
                                    <TextBox x:Name="FullJournalPriceTextBox" HorizontalAlignment="Left" 
                                             Text="{Binding CraftingBindings.Journal.FullJournalPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Width="90" Height="22" common:TextBoxHelper.OnlyNumeric="Double" GotKeyboardFocus="JournalFullPrice_OnGotKeyboardFocus"
                                             PreviewMouseLeftButtonDown="PriceTextBox_OnPreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="JournalFullPrice_OnPreviewMouseLeftButtonUp" />
                                    <Popup PlacementTarget="{Binding ElementName=FullJournalPriceTextBox}"
                                           Placement="Bottom" IsOpen="{Binding CraftingBindings.Journal.IsFullJournalPricePopupOpen, Mode=TwoWay}"
                                           StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">
                                        <Border DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type Popup}}}"
                                                Background="{StaticResource SolidColorBrush.Background.2}"
                                                BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}"
                                                BorderThickness="1" Width="230" MaxHeight="360">
                                            <ListBox SelectionMode="Single"
                                                     SelectionChanged="ListBoxJournalFullPrice_OnSelectionChanged"
                                                     ItemsSource="{Binding CraftingBindings.Journal.FullJournalPriceOptions}" Width="230" MinHeight="38" 
                                                     MaxHeight="360" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding DisplayText}" ToolTip="{Binding UpdateDateTimeText}" Style="{StaticResource CraftingSellPriceOptionText}" />
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" MinWidth="300">
