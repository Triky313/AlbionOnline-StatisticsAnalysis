                                        <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource {x:Type GridViewColumnHeader}}">
                                            <Setter Property="ToolTip" Value="{x:Static crafting:CraftingBindings.TranslationResourceNetColumnTooltip}" />
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding NetQuantity, StringFormat={}{0:#,0.##}}" Style="{StaticResource CraftingResourceNetQuantityText}" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationPrice}" Width="110">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource {x:Type GridViewColumnHeader}}">
                                            <Setter Property="ToolTip" Value="{x:Static crafting:CraftingBindings.TranslationResourcePriceColumnTooltip}" />
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <TextBox x:Name="ResourceUnitPriceTextBox"
                                                         Text="{Binding UnitPrice, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         Width="78"
                                                         Height="22"
                                                         common:TextBoxHelper.OnlyNumeric="Double"
                                                         GotKeyboardFocus="ResourcePrice_OnGotKeyboardFocus"
                                                         PreviewMouseLeftButtonDown="PriceTextBox_OnPreviewMouseLeftButtonDown"
                                                         PreviewMouseLeftButtonUp="ResourcePrice_OnPreviewMouseLeftButtonUp" />
                                                <Popup PlacementTarget="{Binding ElementName=ResourceUnitPriceTextBox}"
                                                       Placement="Bottom"
                                                       IsOpen="{Binding IsPricePopupOpen, Mode=TwoWay}"
                                                       StaysOpen="False"
                                                       AllowsTransparency="True"
                                                       PopupAnimation="Slide">
                                                    <Border DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType={x:Type Popup}}}"
                                                            Background="{StaticResource SolidColorBrush.Background.2}"
                                                            BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}"
                                                            BorderThickness="1"
                                                            Width="230"
                                                            MaxHeight="360">
                                                        <ListBox SelectionMode="Single"
                                                                 SelectionChanged="ListBoxResourcePrice_OnSelectionChanged"
                                                                 ItemsSource="{Binding PriceOptions}"
                                                                 Tag="{Binding}"
                                                                 Width="230"
                                                                 MinHeight="38"
                                                                 MaxHeight="360"
                                                                 BorderThickness="0"
                                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                            <ListBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding DisplayText}" ToolTip="{Binding UpdateDateTimeText}" Style="{StaticResource CraftingSellPriceOptionText}" />
                                                                </DataTemplate>
                                                            </ListBox.ItemTemplate>
                                                        </ListBox>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="{x:Static crafting:CraftingBindings.TranslationNetCost}" Width="110">
                                    <GridViewColumn.HeaderContainerStyle>
                                        <Style TargetType="{x:Type GridViewColumnHeader}" BasedOn="{StaticResource {x:Type GridViewColumnHeader}}">
                                            <Setter Property="ToolTip" Value="{x:Static crafting:CraftingBindings.TranslationResourceNetCostColumnTooltip}" />
                                        </Style>
                                    </GridViewColumn.HeaderContainerStyle>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding NetCost, StringFormat={}{0:N0}}" Style="{StaticResource CraftingResourceCostText}" />
                                                <Image Style="{StaticResource Icon.Silver}" Margin="5,0,0,0" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Grid Margin="0,12,0,0">
