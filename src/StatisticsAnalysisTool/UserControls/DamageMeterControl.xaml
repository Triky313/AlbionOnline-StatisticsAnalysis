<UserControl x:Class="StatisticsAnalysisTool.UserControls.DamageMeterControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa5="http://schemas.fontawesome.com/icons/"
             xmlns:damageMeter="clr-namespace:StatisticsAnalysisTool.DamageMeter"
             xmlns:viewModels="clr-namespace:StatisticsAnalysisTool.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=viewModels:MainWindowViewModel}">
    <UserControl.Resources>
        <DataTemplate x:Key="DamageStatsEntryTemplate" DataType="{x:Type damageMeter:DamageStatsEntry}">
            <Grid Margin="0,0,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Rank, StringFormat='{}{0}.'}" Foreground="{StaticResource SolidColorBrush.Text.2}" FontSize="14" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Text="{Binding PlayerName}" Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2" Text="{Binding ValueString}" Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" HorizontalAlignment="Right"  />
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="YourStatsTopEntryTemplate" DataType="{x:Type damageMeter:DamageMeterYourStatsTopEntry}">
            <Grid Margin="14,0,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Rank, StringFormat='{}{0}.'}" Foreground="{StaticResource SolidColorBrush.Text.2}" FontSize="14" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2" Text="{Binding ValueString}" Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" HorizontalAlignment="Right" FontWeight="Bold" />
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="YourStatsHealingTopEntryTemplate" DataType="{x:Type damageMeter:DamageMeterYourStatsTopEntry}">
            <Grid Margin="14,0,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Rank, StringFormat='{}{0}.'}" Foreground="{StaticResource SolidColorBrush.Text.2}" FontSize="14" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="2" Text="{Binding ValueString}" Foreground="{StaticResource SolidColorBrush.Accent.Green.3}" HorizontalAlignment="Right" FontWeight="Bold" />
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="YourStatsSnapshotTemplate" DataType="{x:Type damageMeter:DamageMeterYourStatsSnapshot}">
            <Grid Margin="0,5,0,0">
                <ScrollViewer Visibility="{Binding ContentVisibility}">
                    <UniformGrid Columns="2">
                        <Border Margin="0,2,10,8" Padding="5" BorderBrush="{StaticResource SolidColorBrush.Accent.Red.2}" BorderThickness="0,1,0,0">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.DamageMeterBindings.TranslationYourStatsDamageSection, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=YOUR_STATS_DAMAGE_SECTION}"
                                           Foreground="{StaticResource SolidColorBrush.Accent.Red.2}" FontWeight="Bold" Margin="0,0,0,4" FontSize="14" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DataContext.DamageMeterBindings.TranslationTotalDamage, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=TOTAL_DAMAGE}"
                                               Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalDamage}" Foreground="{StaticResource SolidColorBrush.Accent.Red.2}"
                                               HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding DataContext.DamageMeterBindings.TranslationTotalDps, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=TOTAL_DPS}"
                                               Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TotalDps}" Foreground="{StaticResource SolidColorBrush.Accent.Red.2}"
                                               HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding DataContext.DamageMeterBindings.TranslationPeakDpsThreeSeconds, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=PEAK_DPS_3_SECONDS}"
                                               Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PeakDpsThreeSeconds}" Foreground="{StaticResource SolidColorBrush.Accent.Red.2}"
                                               HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{Binding DataContext.DamageMeterBindings.TranslationPeakDpsFiveSeconds, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=PEAK_DPS_5_SECONDS}"
                                               Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PeakDpsFiveSeconds}" Foreground="{StaticResource SolidColorBrush.Accent.Red.2}"
                                               HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{Binding DataContext.DamageMeterBindings.TranslationPeakDpsTenSeconds, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=PEAK_DPS_10_SECONDS}"
                                               Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PeakDpsTenSeconds}" Foreground="{StaticResource SolidColorBrush.Accent.Red.2}"
                                               HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="{Binding DataContext.DamageMeterBindings.TranslationBiggestHit, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=BIGGEST_HIT}"
                                               Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding BiggestHit}" Foreground="{StaticResource SolidColorBrush.Accent.Red.2}"
                                               HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="{Binding DataContext.DamageMeterBindings.TranslationPveDamage, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=PVE_DAMAGE}"
                                               Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding PveDamage}" Foreground="{StaticResource SolidColorBrush.Accent.Red.2}"
                                               HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="{Binding DataContext.DamageMeterBindings.TranslationPvpDamage, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=PVP_DAMAGE}"
                                               Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" />
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding PvpDamage}" Foreground="{StaticResource SolidColorBrush.Accent.Red.2}"
                                               HorizontalAlignment="Right" FontWeight="Bold" />
                                </Grid>
                            </DockPanel>
                        </Border>
                        <Border Margin="10,2,0,8" Padding="5" BorderBrush="{StaticResource SolidColorBrush.Accent.Green.3}" BorderThickness="0,1,0,0">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.DamageMeterBindings.TranslationYourStatsHealingSection, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=YOUR_STATS_HEALING_SECTION}"
                                           Foreground="{StaticResource SolidColorBrush.Accent.Green.3}" FontWeight="Bold" Margin="0,0,0,4" FontSize="14" />
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DataContext.DamageMeterBindings.TranslationTotalHealing, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=TOTAL_HEALING}" Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" Margin="0,0,0,5" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalHealing}" Foreground="{StaticResource SolidColorBrush.Accent.Green.3}" HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,0,5" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding DataContext.DamageMeterBindings.TranslationEffectiveHealing, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=EFFECTIVE_HEALING}" Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" Margin="0,0,0,5" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding EffectiveHealing}" Foreground="{StaticResource SolidColorBrush.Accent.Green.3}" HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,0,5" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding DataContext.DamageMeterBindings.TranslationOverhealPercent, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=OVERHEAL_PERCENT}" Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" Margin="0,0,0,5" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding OverhealPercent}" Foreground="{StaticResource SolidColorBrush.Accent.Green.3}" HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,0,5" />
                                    </Grid>
                                    <TextBlock Text="{Binding DataContext.DamageMeterBindings.TranslationHealingTargetsTopThree, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=HEALING_TARGETS_TOP_3}"
                                               Foreground="{StaticResource SolidColorBrush.Text.3}" FontWeight="Bold" Margin="0,7,0,3" FontSize="14" />
                                    <ItemsControl ItemsSource="{Binding TopHealingTargets}" ItemTemplate="{StaticResource YourStatsHealingTopEntryTemplate}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <Border Margin="0,2,10,8" Padding="5" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}" BorderThickness="0,1,0,0">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.DamageMeterBindings.TranslationYourStatsDefenseSection, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=YOUR_STATS_DEFENSE_SECTION}"
                                           Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" FontWeight="Bold" Margin="0,0,0,4" FontSize="14" />
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DataContext.DamageMeterBindings.TranslationDamageTaken, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=DAMAGE_TAKEN}" Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" Margin="0,0,0,5" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DamageTaken}" Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,0,5" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding DataContext.DamageMeterBindings.TranslationDtps, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=DTPS}" ToolTip="{Binding DataContext.DamageMeterBindings.TranslationDtpsTooltip, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=DTPS_TOOLTIP}" Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" Margin="0,0,0,5" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Dtps}" ToolTip="{Binding DataContext.DamageMeterBindings.TranslationDtpsTooltip, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=DTPS_TOOLTIP}" Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,0,5" />
                                    </Grid>
                                    <TextBlock Text="{Binding DataContext.DamageMeterBindings.TranslationBiggestDamageTakenBySpellTopThree, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=BIGGEST_DAMAGE_TAKEN_BY_SPELL_TOP_3}"
                                               Foreground="{StaticResource SolidColorBrush.Text.2}" FontWeight="Bold" Margin="0,7,0,3" FontSize="14" />
                                    <ItemsControl ItemsSource="{Binding TopDamageTakenBySpell}" ItemTemplate="{StaticResource YourStatsTopEntryTemplate}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <Border Margin="10,2,0,8" Padding="5" BorderBrush="{StaticResource SolidColorBrush.Accent.Yellow.3}" BorderThickness="0,1,0,0">
                            <DockPanel LastChildFill="True">
                                <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.DamageMeterBindings.TranslationYourStatsCombatSection, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=YOUR_STATS_COMBAT_SECTION}"
                                           Foreground="{StaticResource SolidColorBrush.Accent.Yellow.3}" FontWeight="Bold" Margin="0,0,0,4" FontSize="14" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding DataContext.DamageMeterBindings.TranslationCombatTime, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=COMBAT_TIME}" Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CombatTime}" Foreground="{StaticResource SolidColorBrush.Accent.Yellow.3}" HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding DataContext.DamageMeterBindings.TranslationFightCount, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=FIGHT_COUNT}" Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding FightCount}" Foreground="{StaticResource SolidColorBrush.Accent.Yellow.3}" HorizontalAlignment="Right" FontWeight="Bold" Margin="0,0,0,5" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding DataContext.DamageMeterBindings.TranslationAverageFightDuration, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=AVERAGE_FIGHT_DURATION}" Foreground="{StaticResource SolidColorBrush.Text.1}" FontSize="14" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AverageFightDuration}" Foreground="{StaticResource SolidColorBrush.Accent.Yellow.3}" HorizontalAlignment="Right" FontWeight="Bold" />
                                </Grid>
                            </DockPanel>
                        </Border>
                    </UniformGrid>
                </ScrollViewer>
                <TextBlock Text="{Binding DataContext.DamageMeterBindings.TranslationNoLocalDamageStatsAvailable, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=NO_LOCAL_DAMAGE_STATS_AVAILABLE}"
                           Visibility="{Binding EmptyVisibility}" Foreground="{StaticResource SolidColorBrush.Text.2}" FontSize="14" Margin="5" />
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="DamageStatsSnapshotTemplate" DataType="{x:Type damageMeter:DamageStatsSnapshot}">
            <ScrollViewer Margin="0,5,0,0">
                <ItemsControl>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <Border Margin="0,2,10,0" Padding="5" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}" BorderThickness="0,1,0,0">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.DamageMeterBindings.TranslationBiggestSingleHitTop5, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=BIGGEST_SINGLE_HIT_TOP_5}"
                                       Foreground="{StaticResource SolidColorBrush.Accent.Red.1}" FontWeight="Bold" Margin="0,0,0,2" FontSize="14" />
                            <ItemsControl ItemsSource="{Binding TopSingleHits}" ItemTemplate="{StaticResource DamageStatsEntryTemplate}" />
                        </DockPanel>
                    </Border>
                    <Border Margin="10,2,0,0" Padding="5" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}" BorderThickness="0,1,0,0">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.DamageMeterBindings.TranslationBiggestSingleHealTop5, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=BIGGEST_SINGLE_HEAL_TOP_5}"
                                       Foreground="{StaticResource SolidColorBrush.Accent.Green.2}" FontWeight="Bold" Margin="0,0,0,2" FontSize="14" />
                            <ItemsControl ItemsSource="{Binding TopSingleHeals}" ItemTemplate="{StaticResource DamageStatsEntryTemplate}" />
                        </DockPanel>
                    </Border>
                    <Border Margin="0,2,10,0" Padding="5" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}" BorderThickness="0,1,0,0">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.DamageMeterBindings.TranslationLastHitsTop5, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=LAST_HITS_TOP_5}"
                                       Foreground="{StaticResource SolidColorBrush.Accent.Red.2}" FontWeight="Bold" Margin="0,0,0,2" FontSize="14" />
                            <ItemsControl ItemsSource="{Binding TopLastHits}" ItemTemplate="{StaticResource DamageStatsEntryTemplate}" />
                        </DockPanel>
                    </Border>
                    <Border Margin="10,2,0,0" Padding="5" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}" BorderThickness="0,1,0,0">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.DamageMeterBindings.TranslationOverhealTop5, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=OVERHEAL_TOP_5}"
                                       Foreground="{StaticResource SolidColorBrush.Accent.Green.5}" FontWeight="Bold" Margin="0,0,0,2" FontSize="14" />
                            <ItemsControl ItemsSource="{Binding TopOverheals}" ItemTemplate="{StaticResource DamageStatsEntryTemplate}" />
                        </DockPanel>
                    </Border>
                    <Border Margin="0,2,10,0" Padding="5" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}" BorderThickness="0,1,0,0">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.DamageMeterBindings.TranslationDamageTakenTop5, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=DAMAGE_TAKEN_TOP_5}"
                                       Foreground="{StaticResource SolidColorBrush.Accent.Red.5}" FontWeight="Bold" Margin="0,0,0,2" FontSize="14" />
                            <ItemsControl ItemsSource="{Binding TopTakenDamage}" ItemTemplate="{StaticResource DamageStatsEntryTemplate}" />
                        </DockPanel>
                    </Border>
                    <Border Margin="10,2,0,0" Padding="5" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}" BorderThickness="0,1,0,0">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.DamageMeterBindings.TranslationBurstDamageFiveSecondsTop5, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=BURST_DAMAGE_5_SECONDS_TOP_5}"
                                       Foreground="{StaticResource SolidColorBrush.Accent.Red.3}" FontWeight="Bold" Margin="0,0,0,2" FontSize="14" />
                            <ItemsControl ItemsSource="{Binding TopBurstDamageFiveSeconds}" ItemTemplate="{StaticResource DamageStatsEntryTemplate}" />
                        </DockPanel>
                    </Border>
                    <Border Margin="0,2,10,0" Padding="5" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}" BorderThickness="0,1,0,0">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.DamageMeterBindings.TranslationBurstDamageTenSecondsTop5, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=BURST_DAMAGE_10_SECONDS_TOP_5}"
                                       Foreground="{StaticResource SolidColorBrush.Accent.Red.3}" FontWeight="Bold" Margin="0,0,0,2" FontSize="14" />
                            <ItemsControl ItemsSource="{Binding TopBurstDamageTenSeconds}" ItemTemplate="{StaticResource DamageStatsEntryTemplate}" />
                        </DockPanel>
                    </Border>
                    <Border Margin="10,2,0,0" Padding="5" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.4}" BorderThickness="0,1,0,0">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Top" Text="{Binding DataContext.DamageMeterBindings.TranslationAttackedMobsPlayersTop5, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, FallbackValue=ATTACKED_MOBS_PLAYERS_TOP_5}"
                                       Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" FontWeight="Bold" Margin="0,0,0,2" FontSize="14" />
                            <ItemsControl ItemsSource="{Binding TopAttackedTargets}" ItemTemplate="{StaticResource DamageStatsEntryTemplate}" />
                        </DockPanel>
                    </Border>
                </ItemsControl>
            </ScrollViewer>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <TabControl Background="Transparent" BorderThickness="0">
            <TabItem Header="{Binding DamageMeterBindings.TranslationLive, FallbackValue=LIVE}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="31"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid Height="25" Width="35" Margin="0,0,5,0" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <fa5:ImageAwesome Visibility="Visible"
                                              ToolTip="{Binding Translation.DamageMeterOnOff, FallbackValue=DAMAGE__METER__ON__OFF}"
                                              Icon="{Binding DamageMeterBindings.DamageMeterActivationToggleIcon, FallbackValue=Solid_ToggleOff}"
                                              Foreground="{Binding DamageMeterBindings.DamageMeterActivationToggleColor, FallbackValue={StaticResource SolidColorBrush.Text.1}}"
                                              MouseUp="DamageMeterModeActiveToggle_MouseUp" />
                        </Grid>
                        <Button Content="{Binding Translation.ResetDamageMeter, FallbackValue=RESET__DAMAGE__METER}" Height="26" MaxWidth="500" MinWidth="200"
                                Style="{StaticResource Style.Button.Danger}" Margin="0,0,5,0" Width="auto" HorizontalAlignment="Right" VerticalAlignment="Center" Click="BtnDamageMeterReset_Click" />
                    </Grid>
                    <Separator Grid.Row="1" Background="{StaticResource SolidColorBrush.Background.2}" Height="4" VerticalAlignment="Top"/>
                    <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">
                    <TabItem Header="{Binding DamageMeterBindings.TranslationMeter, FallbackValue=METER}">
                        <Grid>
                   <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="{Binding DamageMeterBindings.GridSplitterPosition ,Mode=TwoWay, FallbackValue=*}"/>
                        </Grid.RowDefinitions>

                        <GridSplitter Grid.Row="1" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" HorizontalAlignment="Stretch" Margin="0,0,1,1" 
                                      Background="{StaticResource SolidColorBrush.Accent.Blue.4}" />

                        <Grid Row="0" Margin="0,0,0,6" Grid.RowSpan="2">
                            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left">
                                <Grid Margin="0,0,0,0" Height="30">
                                    <ComboBox Width="200" Height="26" Margin="0,0,0,0" HorizontalAlignment="Left" ItemsSource="{Binding DamageMeterBindings.DamageMeterSort}"
                                              SelectedItem="{Binding DamageMeterBindings.DamageMeterSortSelection}"
                                              IsSynchronizedWithCurrentItem="True" DisplayMemberPath="Name" SelectedValuePath="DamageMeterSortType" />
                                </Grid>

                                <Label Content="{Binding Translation.Settings, FallbackValue=SETTINGS}" Style="{StaticResource HeaderStyle.Tracking.Title}" Margin="10,10,0,0"
                                       Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" />
                                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Vertical">
                                    <CheckBox IsChecked="{Binding DamageMeterBindings.IsDamageMeterResetByMapChangeActive}" 
                                          Content="{Binding Translation.MapChangeReset, FallbackValue=MAP__CHANGE__RESET}" 
                                          HorizontalContentAlignment="Left" Margin="5,2,10,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="auto"/>
                                    <CheckBox IsChecked="{Binding DamageMeterBindings.IsDamageMeterResetBeforeCombatActive}" 
                                          Content="{Binding Translation.ResetBeforeCombat, FallbackValue=RESET__BEFORE__COMBAT}" 
                                          HorizontalContentAlignment="Left" Margin="5,2,10,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="auto"/>
                                    <CheckBox IsChecked="{Binding DamageMeterBindings.IsSnapshotAfterMapChangeActive}" 
                                          Content="{Binding Translation.SnapshotAfterMapChange, FallbackValue=SNAPSHOT__AFTER__MAP__CHANGE}" 
                                          HorizontalContentAlignment="Left" Margin="5,2,10,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="auto"/>
                                    <CheckBox IsChecked="{Binding DamageMeterBindings.ShortDamageMeterToClipboard}" 
                                              Content="{Binding Translation.CopyShortDamageMeterToTheClipboard, FallbackValue=COPY__SHORT__DAMAGE__METER__TO__THE__CLIPBOARD}" 
                                              HorizontalContentAlignment="Left" Margin="5,2,10,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="auto"/>
                                    <CheckBox IsChecked="{Binding DamageMeterBindings.OnlyDamageToPlayersCounts}" 
                                              Content="{Binding Translation.OnlyDamageToPlayersCounts, FallbackValue=ONLY__DAMAGE__TO__PLAYERS__COUNTS}" 
                                              HorizontalContentAlignment="Left" Margin="5,2,10,0" VerticalAlignment="Top" HorizontalAlignment="Left" Width="auto"/>
                                </StackPanel>
                            </StackPanel>

                            <Grid HorizontalAlignment="Right" Width="300" Height="30" VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Grid Height="20" Width="20" Margin="5,0,5,0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                          ToolTip="{Binding Translation.OpenExtendedDamageMeterWindow, FallbackValue=OPEN__EXTENDED__DAMAGE__METER__WINDOW}"
                                          MouseUp="OpenDamageMeterWindow_MouseUp">
                                        <fa5:ImageAwesome Icon="Solid_Expand" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                                    </Grid>
                                    <Grid Height="20" Width="20" Margin="5,0,5,0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                          ToolTip="{Binding Translation.CopyToClipboard, FallbackValue=COPY__TO__CLIPBOARD}" MouseUp="CopyDamageMeterToClipboard_MouseUp">
                                        <fa5:ImageAwesome Icon="Regular_Copy" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                                    </Grid>
                                    <Grid Height="20" Width="20" Margin="5,0,5,0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                          ToolTip="{Binding DamageMeterBindings.TranslationTakeASnapshotOfDamageMeterDescription, FallbackValue=TAKE_A_SNAPSHOT_OF_DAMAGE_METER}"
                                          MouseUp="TakeASnapShot_MouseUp">
                                        <fa5:ImageAwesome Icon="Solid_Camera" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                                    </Grid>
                                    <Grid Height="20" Width="20" Margin="5,0,0,0" HorizontalAlignment="Right" VerticalAlignment="Center"
                                          MouseEnter="OpenDamageMeterInfoPopup_MouseEnter" MouseLeave="CloseDamageMeterInfoPopup_MouseLeave">
                                        <fa5:ImageAwesome Icon="Solid_InfoCircle" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <Grid Row="2">
                            <ScrollViewer Margin="-3,0,0,0">
                                <ItemsControl ItemsSource="{Binding DamageMeterBindings.DamageMeter, IsAsync=True, Mode=OneWay}" ItemTemplate="{StaticResource DamageMeterFragmentTemplate}" />
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                    <Grid Visibility="{Binding IsDamageMeterPopupVisible, FallbackValue=Hidden}" Margin="0,65,0,0" Background="{StaticResource SolidColorBrush.Background.2}">
                        <StackPanel CanHorizontallyScroll="False" CanVerticallyScroll="True" Margin="10,0">
                            <DockPanel Margin="0,0,0,16">
                                <Grid Height="16" Width="16" Margin="0,3,10,0" VerticalAlignment="Top">
                                    <fa5:ImageAwesome Icon="Regular_DotCircle" Foreground="{StaticResource SolidColorBrush.Accent.Blue.3}" />
                                </Grid>
                                <TextBlock Text="{Binding Translation.DamageMeterDescription1}" Foreground="{StaticResource SolidColorBrush.Text.1}" 
                               FontSize="16" TextWrapping="Wrap" Width="auto" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,16">
                                <Grid Height="16" Width="16" Margin="0,3,10,0" VerticalAlignment="Top">
                                    <fa5:ImageAwesome Icon="Regular_DotCircle" Foreground="{StaticResource SolidColorBrush.Accent.Blue.3}" />
                                </Grid>
                                <TextBlock Text="{Binding Translation.DamageMeterDescription2}" Foreground="{StaticResource SolidColorBrush.Text.1}" 
                                           FontSize="16" TextWrapping="Wrap" Width="auto" />
                            </DockPanel>
                        </StackPanel>
                    </Grid>
                        </Grid>
                    </TabItem>
                    <TabItem Header="{Binding DamageMeterBindings.TranslationTopStats, FallbackValue=TOP_STATS}">
                        <ContentControl Content="{Binding DamageMeterBindings.CurrentDamageStats}" ContentTemplate="{StaticResource DamageStatsSnapshotTemplate}" />
                    </TabItem>
                    <TabItem Header="{Binding DamageMeterBindings.TranslationYourStats, FallbackValue=YOUR_STATS}">
                        <ContentControl Content="{Binding DamageMeterBindings.CurrentYourStats}" ContentTemplate="{StaticResource YourStatsSnapshotTemplate}" />
                    </TabItem>
                </TabControl>
                </Grid>
            </TabItem>
            <TabItem Header="{Binding DamageMeterBindings.TranslationSnapshots, FallbackValue=SNAPSHOTS}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="31"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Left">
                        <ComboBox Width="200" Height="26" Margin="2,0,5,0" 
                                  ItemsSource="{Binding DamageMeterBindings.DamageMeterSnapshots}" 
                                  SelectedItem="{Binding DamageMeterBindings.DamageMeterSnapshotSelection}" 
                                  IsSynchronizedWithCurrentItem="True" DisplayMemberPath="TimestampString" SelectedValuePath="DamageMeter" />
                        <Button Content="{Binding DamageMeterBindings.TranslationDeleteSelectedSnapshot, FallbackValue=DELETE__SELECTED__SNAPSHOT}" 
                                MaxWidth="500" MinWidth="200" Margin="5,0,5,0" Style="{StaticResource Style.Button.Danger}" Click="BtnDeleteSelectedSnapshot_Click" />
                        <Grid Height="20" Width="20" Margin="5,0,5,0" HorizontalAlignment="Right" VerticalAlignment="Center" 
                              ToolTip="{Binding DamageMeterBindings.TranslationDeleteAllSnapshots, FallbackValue=DELETE__ALL__SNAPSHOTS}" MouseUp="DeleteAllDamageMeterSnapshots_MouseUp">
                            <fa5:ImageAwesome Icon="Regular_TrashAlt" Foreground="{StaticResource SolidColorBrush.Accent.Red.5}" />
                        </Grid>
                        <Grid Height="20" Width="20" Margin="5,0,5,0" HorizontalAlignment="Right" VerticalAlignment="Center" 
                              ToolTip="{Binding Translation.CopyToClipboard, FallbackValue=COPY__TO__CLIPBOARD}" MouseUp="CopyDamageMeterSnapshotToClipboard_MouseUp">
                            <fa5:ImageAwesome Icon="Regular_Copy" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                        </Grid>
                    </StackPanel>
                    <Separator Grid.Row="1" Background="{StaticResource SolidColorBrush.Background.2}" Height="4" VerticalAlignment="Top"/>
                    <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">
                        <TabItem Header="{Binding DamageMeterBindings.TranslationMeter, FallbackValue=METER}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <ComboBox Grid.Row="0" Width="200" Height="26" HorizontalAlignment="Left"
                                          ItemsSource="{Binding DamageMeterBindings.DamageMeterSnapshotSort}"
                                          SelectedItem="{Binding DamageMeterBindings.DamageMeterSnapshotSortSelection}"
                                          IsSynchronizedWithCurrentItem="True" DisplayMemberPath="Name" SelectedValuePath="DamageMeterSortType" />
                                <ScrollViewer Grid.Row="1" Margin="-3,0,0,0">
                                    <ItemsControl ItemsSource="{Binding DamageMeterBindings.DamageMeterSnapshotSelection.DamageMeter, IsAsync=True, Mode=OneWay}"
                                                  ItemTemplate="{StaticResource DamageMeterSnapshotFragmentTemplate}" />
                                </ScrollViewer>
                            </Grid>
                        </TabItem>
                        <TabItem Header="{Binding DamageMeterBindings.TranslationTopStats, FallbackValue=TOP_STATS}">
                            <ContentControl Content="{Binding DamageMeterBindings.SnapshotDamageStats}" ContentTemplate="{StaticResource DamageStatsSnapshotTemplate}" />
                        </TabItem>
                        <TabItem Header="{Binding DamageMeterBindings.TranslationYourStats, FallbackValue=YOUR_STATS}">
                            <ContentControl Content="{Binding DamageMeterBindings.SnapshotYourStats}" ContentTemplate="{StaticResource YourStatsSnapshotTemplate}" />
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
