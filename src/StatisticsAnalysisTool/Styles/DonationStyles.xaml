    <Style TargetType="Image" x:Key="Donation.Image.Silver.Style">
        <Setter Property="Source" Value="../Resources/silver.png" />
        <Setter Property="Visibility" Value="Collapsed" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Margin" Value="0,0,0,0" />
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="26" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsDonationRealMoney}" Value="false">
                <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="fa5:ImageAwesome" x:Key="Donation.Image.RealMoney.Style">
        <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Text.1}" />
