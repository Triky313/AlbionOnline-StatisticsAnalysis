        <Setter Property="MinWidth" Value="160" />
        <Setter Property="Margin" Value="0,0,0,0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style TargetType="TextBlock" x:Key="Donation.TextBlock.Server.Style">
