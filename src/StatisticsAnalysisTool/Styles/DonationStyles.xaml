        <Setter Property="MinWidth" Value="160" />
        <Setter Property="Margin" Value="5,0,0,0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style TargetType="{x:Type ProgressBar}" x:Key="Donation.ProgressBar.Goal.Style">
        <Setter Property="Width" Value="640" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Background" Value="{StaticResource SolidColorBrush.Background.7}" />
        <Setter Property="BorderBrush" Value="{StaticResource SolidColorBrush.Background.4}" />
        <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Yellow.1}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ProgressBar}">
                    <Grid ClipToBounds="True">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="3" />
                        <Grid x:Name="PART_Track" Margin="1" />
                        <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="3" HorizontalAlignment="Left" Margin="1" ClipToBounds="True">
                            <Grid>
                                <Rectangle x:Name="DonationProgressShimmer" Width="110" HorizontalAlignment="Left">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#00FFFFFF" Offset="0" />
                                            <GradientStop Color="#55FFFFFF" Offset="0.5" />
                                            <GradientStop Color="#00FFFFFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                    <Rectangle.RenderTransform>
                                        <TranslateTransform X="-120" />
                                    </Rectangle.RenderTransform>
                                    <Rectangle.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                    <DoubleAnimation Storyboard.TargetName="DonationProgressShimmer"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                     From="-120"
                                     To="720"
                                     Duration="0:0:2.8" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Rectangle.Triggers>
                                </Rectangle>
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type TextBlock}" x:Key="Donation.TextBlock.Placement.Style">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Light" />
        <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Yellow.1}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding Placement}" Value="1">
                <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Blue.3}" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Placement}" Value="2">
                <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Blue.2}" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Placement}" Value="3">
                <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Blue.1}" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

