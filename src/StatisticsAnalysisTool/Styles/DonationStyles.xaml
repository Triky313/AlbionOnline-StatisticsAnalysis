    <Style TargetType="{x:Type ItemsControl}" x:Key="Donation.ItemsControl.TwoColumns.Style">
        <Setter Property="Width" Value="800" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="{x:Type ContentPresenter}">
                    <Setter Property="Margin" Value="0,0,10,4" />
                    <Setter Property="HorizontalAlignment" Value="Left" />
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <DataTemplate x:Key="Donation" DataType="{x:Type models:Donation}">
        <Grid Width="390" MinHeight="56" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32" />
                <ColumnDefinition Width="112" />
                <ColumnDefinition Width="50" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding Placement, StringFormat='{}{0}.'}" Style="{StaticResource Donation.TextBlock.Placement.Style}" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="{Binding DonationSilverVisibility}" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Image Style="{StaticResource Donation.Image.Silver.Style}" Width="24" Height="24" ToolTip="{Binding TranslationSilver}" />
                <StackPanel Orientation="Vertical">
                    <TextBlock Style="{StaticResource Donation.TextBlock.Amount.Compact.Style}" Text="{Binding Amount, StringFormat='{} {0:N0}'}" />
                    <TextBlock Style="{StaticResource Donation.TextBlock.Server.Compact.Style}" Text="{Binding DonationServer}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="{Binding DonationRealMoneyVisibility}" HorizontalAlignment="Left" VerticalAlignment="Center">
                <fa5:ImageAwesome Style="{StaticResource Donation.Image.RealMoney.Style}" Width="18" Height="18" />
                <TextBlock Style="{StaticResource Donation.TextBlock.Amount.Compact.Style}" Text="{Binding RealMoneyAmount, StringFormat='{} {0:N2}'}" />
            </StackPanel>

            <Image Grid.Column="2" Style="{StaticResource Donation.Icon.Style}" Width="72" Height="72" HorizontalAlignment="Left" />
            <TextBlock Grid.Column="3" Text="{Binding Contributor}" Margin="10,0" ToolTip="{Binding Contributor}" Style="{StaticResource Donation.TextBlock.Contributor.Style}" />
        </Grid>
    </DataTemplate>

</ResourceDictionary>