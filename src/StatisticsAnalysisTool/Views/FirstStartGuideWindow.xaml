<Window x:Class="StatisticsAnalysisTool.Views.FirstStartGuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:StatisticsAnalysisTool.ViewModels"
        xmlns:fa5="http://schemas.fontawesome.com/icons/"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:FirstStartGuideViewModel}"
        Title="{Binding WindowTitle}"
        Height="560"
        Width="820"
        MinHeight="560"
        MinWidth="820"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SolidColorBrush.Background.1}"
        FontSize="{StaticResource BaseFontSize}"
        WindowStyle="None"
        ShowInTaskbar="True"
        ResizeMode="NoResize">
    <Grid>
        <Border BorderThickness="1,0,0,0" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.2}" />
        <Border BorderThickness="0,1,0,0" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.2}" />
        <Border BorderThickness="0,0,1,0" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.2}" />
        <Border BorderThickness="0,0,0,1" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.2}" />

        <Grid ZIndex="1" Height="33" VerticalAlignment="Top" Background="{StaticResource SolidColorBrush.Background.3}" MouseDown="Hotbar_MouseDown">
            <Border BorderThickness="1,0,0,0" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.2}" />
            <Border BorderThickness="0,1,0,0" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.2}" />
            <Border BorderThickness="0,0,1,0" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.2}" />
            <Grid Margin="10,4,0,0" Width="24" Height="24" VerticalAlignment="Top" HorizontalAlignment="Left">
                <fa5:ImageAwesome Icon="Solid_Tasks" Foreground="{StaticResource SolidColorBrush.Accent.Blue.3}" />
            </Grid>
            <Label Content="{Binding WindowTitle}"
                   Margin="41,0,61,0"
                   VerticalAlignment="Top"
                   Height="33"
                   FontSize="16"
                   Foreground="{StaticResource SolidColorBrush.Text.1}"
                   FontWeight="Bold" />
            <Button x:Name="CloseButton" Style="{StaticResource WindowButtonStyle}" Content="r" Margin="-2,2,2,0" Click="CloseButton_Click" />
        </Grid>

        <Grid Margin="30,55,30,96">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Vertical">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding StepCounterText}"
                               Foreground="{StaticResource SolidColorBrush.Text.4}"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="15,0,0,0" />
                    <TextBlock Text="{Binding CurrentStepTitle}"
                               Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}"
                               FontSize="24"
                               FontWeight="Bold"
                               TextWrapping="Wrap" />
                </DockPanel>
                <TextBlock Text="{Binding CurrentStepDescription}"
                           Foreground="{StaticResource SolidColorBrush.Text.3}"
                           FontSize="14"
                           TextWrapping="Wrap"
                           Margin="0,7,0,14" />
                <TextBlock Text="{Binding ErrorMessage}"
                           Visibility="{Binding ErrorVisibility}"
                           Foreground="{StaticResource SolidColorBrush.Accent.Red.2}"
                           FontSize="14"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10" />
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid Visibility="{Binding LanguageStepVisibility}">
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" Width="690">
                        <TextBlock Text="{Binding LanguageStepDescription}"
                                   Foreground="{StaticResource SolidColorBrush.Text.1}"
                                   FontSize="16"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,0,0,18" />
                        <ItemsControl ItemsSource="{Binding LanguageOptions}" Margin="0,0,0,18">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Center" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="6,2"
                                            Margin="5">
                                        <TextBlock Text="{Binding DisplayText}"
                                                   FontWeight="Bold"
                                                   TextAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontSize" Value="18" />
                                                    <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Blue.1}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ColorIndex}" Value="1">
                                                            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Blue.2}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ColorIndex}" Value="2">
                                                            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Blue.3}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ColorIndex}" Value="3">
                                                            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Blue.4}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ColorIndex}" Value="4">
                                                            <Setter Property="Foreground" Value="{StaticResource SolidColorBrush.Accent.Blue.5}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ComboBox ItemsSource="{Binding LanguageOptions}"
                                  SelectedItem="{Binding SelectedLanguageOption, Mode=TwoWay}"
                                  SelectedValuePath="Language.FileName"
                                  DisplayMemberPath="Language.DisplayText"
                                  SelectionChanged="LanguageComboBox_SelectionChanged"
                                  FontSize="18"
                                  FontWeight="Bold"
                                  Height="34"
                                  Width="360" />
                    </StackPanel>
                </Grid>

                <Grid Visibility="{Binding ServerStepVisibility}">
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" Width="420">
                        <TextBlock Text="{Binding ServerStepDescription}"
                                   Foreground="{StaticResource SolidColorBrush.Text.1}"
                                   FontSize="16"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,0,0,18" />
                        <ComboBox ItemsSource="{Binding ServerLocations}"
                                  SelectedItem="{Binding SelectedServerLocation}"
                                  SelectedValuePath="ServerLocation"
                                  DisplayMemberPath="Name"
                                  FontSize="18"
                                  FontWeight="Bold"
                                  Height="34" />
                    </StackPanel>
                </Grid>

                <ScrollViewer Visibility="{Binding GameFolderStepVisibility}" VerticalScrollBarVisibility="Auto">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding GameFolderStepDescription}"
                                   Foreground="{StaticResource SolidColorBrush.Text.1}"
                                   FontSize="15"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Width="690"
                                   Margin="0,0,0,12" />
                        <Grid Width="720" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Center">
                                <Label Content="{Binding StandaloneLauncherTitle}" Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" FontSize="16" HorizontalContentAlignment="Center" />
                                <Image Source="../Assets/preparation_folder.png" Height="118" Width="280" Stretch="Uniform" />
                                <TextBlock Text="{Binding StandaloneLauncherMessage}" Foreground="{StaticResource SolidColorBrush.Text.2}" FontSize="12" TextWrapping="Wrap" TextAlignment="Center" Width="300" />
                            </StackPanel>
                            <Separator Grid.Column="1" Background="{StaticResource SolidColorBrush.Accent.Blue.3}" Width="2" Margin="6,0" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" />
                            <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Center">
                                <Label Content="{Binding SteamLauncherTitle}" Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" FontSize="16" HorizontalContentAlignment="Center" />
                                <Image Source="../Assets/preparation_folder_steam.png" Height="118" Width="300" Stretch="Uniform" />
                                <TextBlock Text="{Binding SteamLauncherMessage}" Foreground="{StaticResource SolidColorBrush.Text.2}" FontSize="12" TextWrapping="Wrap" TextAlignment="Center" Width="300" />
                            </StackPanel>
                        </Grid>
                        <DockPanel Width="650" LastChildFill="True" Margin="0,2,0,0">
                            <Button DockPanel.Dock="Right"
                                    Content="{Binding SelectFolderButtonText}"
                                    FontSize="14"
                                    FontWeight="Bold"
                                    Height="32"
                                    Width="210"
                                    Margin="10,0,0,0"
                                    Click="BtnSelectMainGameFolder_Click" />
                            <TextBox Text="{Binding MainGameFolderPath}"
                                     IsReadOnly="True"
                                     Height="32"
                                     FontSize="13"
                                     VerticalContentAlignment="Center" />
                        </DockPanel>
                    </StackPanel>
                </ScrollViewer>

                <Grid Visibility="{Binding TrackingModeStepVisibility}">
                    <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" Width="650">
                        <TextBlock Text="{Binding TrackingModeDifferenceText}"
                                   Foreground="{StaticResource SolidColorBrush.Text.2}"
                                   FontSize="15"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,0,0,18" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,14">
                            <RadioButton Content="{Binding NpcapOptionText}"
                                         GroupName="PacketProvider"
                                         IsChecked="{Binding IsNpcapSelected, Mode=TwoWay}"
                                         FontSize="16"
                                         Margin="0,0,28,0" />
                            <RadioButton Content="{Binding SocketsOptionText}"
                                         GroupName="PacketProvider"
                                         IsChecked="{Binding IsSocketsSelected, Mode=TwoWay}"
                                         FontSize="16" />
                        </StackPanel>
                        <TextBlock Text="{Binding TrackingModeInstructionText}"
                                   Foreground="{StaticResource SolidColorBrush.Text.3}"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   Margin="0,0,0,12" />
                        <TextBlock Visibility="{Binding NpcapDownloadLinkVisibility}"
                                   FontSize="14"
                                   TextAlignment="Center"
                                   Margin="0,0,0,12">
                            <Hyperlink NavigateUri="https://npcap.com/"
                                       Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}"
                                       FontWeight="Bold"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                <Run Text="{Binding NpcapDownloadLinkText, Mode=OneWay}" />
                            </Hyperlink>
                        </TextBlock>
                        <Border Visibility="{Binding NpcapWarningVisibility}"
                                BorderBrush="{StaticResource SolidColorBrush.Accent.Orange.3}"
                                BorderThickness="1"
                                Background="{StaticResource SolidColorBrush.Background.3}"
                                Padding="12"
                                Width="620">
                            <TextBlock Text="{Binding NpcapWarningText}"
                                       Foreground="{StaticResource SolidColorBrush.Accent.Orange.1}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center" />
                        </Border>
                    </StackPanel>
                </Grid>

                <ScrollViewer Visibility="{Binding NavigationTabsStepVisibility}" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding NavigationTabOptions}"
                                  Width="520"
                                  HorizontalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="250"
                                        Margin="5"
                                        Padding="10"
                                        BorderBrush="{StaticResource SolidColorBrush.Background.4}"
                                        BorderThickness="1"
                                        Background="{StaticResource SolidColorBrush.Background.3}">
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Content="{Binding Name}"
                                              Foreground="{StaticResource SolidColorBrush.Text.1}"
                                              FontSize="14"
                                              VerticalContentAlignment="Center" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Grid Visibility="{Binding DonationStepVisibility}">
                    <StackPanel Orientation="Vertical">
                        <TextBlock Text="{Binding DonationHintDescription}" Foreground="{StaticResource SolidColorBrush.Text.2}"
               FontSize="15" TextAlignment="Center" TextWrapping="Wrap" Margin="0,10,0,24" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Width="115" TextAlignment="Center">
            <Hyperlink NavigateUri="{Binding DonateUrl}" RequestNavigate="Hyperlink_RequestNavigate" TextDecorations="{x:Null}">
                <InlineUIContainer BaselineAlignment="Center">
                    <StackPanel Orientation="Vertical" Width="100">
                        <fa5:ImageAwesome Icon="Brands_Paypal" Width="32" Height="32" HorizontalAlignment="Center" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                        <TextBlock Text="PayPal" FontSize="14" Foreground="{StaticResource SolidColorBrush.Text.1}" TextAlignment="Center" Margin="0,8,0,0" />
                    </StackPanel>
                </InlineUIContainer>
            </Hyperlink>
        </TextBlock>
                            <TextBlock Width="115" TextAlignment="Center">
            <Hyperlink NavigateUri="{Binding KofiDonationUrl}" RequestNavigate="Hyperlink_RequestNavigate" TextDecorations="{x:Null}">
                <InlineUIContainer BaselineAlignment="Center">
                    <StackPanel Orientation="Vertical" Width="100">
                        <Image Source="../Assets/ko-fi-icon.png" Width="32" Height="32" HorizontalAlignment="Center" Stretch="Uniform" />
                        <TextBlock Text="Ko-fi" FontSize="14" Foreground="{StaticResource SolidColorBrush.Text.1}" TextAlignment="Center" Margin="0,8,0,0" />
                    </StackPanel>
                </InlineUIContainer>
            </Hyperlink>
        </TextBlock>
        <TextBlock Width="115" TextAlignment="Center">
            <Hyperlink NavigateUri="{Binding PatreonUrl}" RequestNavigate="Hyperlink_RequestNavigate" TextDecorations="{x:Null}">
                <InlineUIContainer BaselineAlignment="Center">
                    <StackPanel Orientation="Vertical" Width="100">
                        <fa5:ImageAwesome Icon="Brands_Patreon" Width="32" Height="32" HorizontalAlignment="Center" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                        <TextBlock Text="Patreon" FontSize="14" Foreground="{StaticResource SolidColorBrush.Text.1}" TextAlignment="Center" Margin="0,8,0,0" />
                    </StackPanel>
                </InlineUIContainer>
            </Hyperlink>
        </TextBlock>
                            <TextBlock Width="115" TextAlignment="Center">
            <Hyperlink NavigateUri="{Binding GitHubSponsorsUrl}" RequestNavigate="Hyperlink_RequestNavigate" TextDecorations="{x:Null}">
                <InlineUIContainer BaselineAlignment="Center">
                    <StackPanel Orientation="Vertical" Width="100">
                        <fa5:ImageAwesome Icon="Regular_Heart" Width="32" Height="32" HorizontalAlignment="Center" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                        <TextBlock Text="GitHub Sponsors" FontSize="14" Foreground="{StaticResource SolidColorBrush.Text.1}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                </InlineUIContainer>
            </Hyperlink>
        </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <Grid Height="82" VerticalAlignment="Bottom" Margin="30,0,30,12">
            <ItemsControl ItemsSource="{Binding StepIndicators}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Ellipse Width="10" Height="10" Margin="5">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource SolidColorBrush.Text.6}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource SolidColorBrush.Accent.Blue.5}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource SolidColorBrush.Accent.Blue.2}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <Button Content="{Binding BackButtonText}"
                        IsEnabled="{Binding IsBackEnabled}"
                        FontSize="15"
                        FontWeight="Bold"
                        Height="34"
                        Width="110"
                        Margin="0,0,10,0"
                        Click="BtnBack_Click" />
                <Button Content="{Binding NextButtonText}"
                        IsEnabled="{Binding IsNextEnabled}"
                        Visibility="{Binding NextButtonVisibility}"
                        FontSize="15"
                        FontWeight="Bold"
                        Height="34"
                        Width="110"
                        Margin="0,0,0,0"
                        Click="BtnNext_Click" />
                <Button Content="{Binding FinishButtonText}"
                        Visibility="{Binding FinishButtonVisibility}"
                        FontSize="15"
                        FontWeight="Bold"
                        Height="34"
                        Width="110"
                        Margin="0,0,0,0"
                        Click="BtnFinish_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
