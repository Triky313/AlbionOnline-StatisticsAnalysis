<Window x:Class="StatisticsAnalysisTool.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:fa5="http://schemas.fontawesome.com/icons/"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:StatisticsAnalysisTool.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:UpdateWindowViewModel}"
        Title="{Binding WindowTitle, FallbackValue=Software Update}"
        Width="740"
        Height="620"
        MinWidth="740"
        AllowsTransparency="True"
        Background="Transparent"
        FontSize="{StaticResource BaseFontSize}"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None">
    <Border Background="{StaticResource SolidColorBrush.Background.1}" BorderBrush="{StaticResource SolidColorBrush.Accent.Blue.2}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="33" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Background="{StaticResource SolidColorBrush.Background.3}"
                  MouseDown="Hotbar_MouseDown"
                  MouseLeftButtonDown="Grid_MouseLeftButtonDown">
                <Grid Margin="10,3,0,0" Width="24" Height="24" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <fa5:ImageAwesome Icon="Solid_Download" Foreground="{StaticResource SolidColorBrush.Accent.Blue.3}" />
                </Grid>
                <Label Margin="41,0,61,0" Height="33" VerticalAlignment="Top" Content="{Binding WindowTitle, FallbackValue=Software Update}"
                       FontSize="16" FontWeight="Bold" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                <Button x:Name="CloseButton" Margin="-2,0,0,0" Click="CloseButton_Click" Content="r" Style="{StaticResource WindowButtonStyle}" />
            </Grid>

            <Grid Grid.Row="1" Margin="16,16,16,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding Headline, FallbackValue=A new version is available.}"
                           FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource SolidColorBrush.Text.1}" TextWrapping="Wrap" />

                <TextBlock Grid.Row="1" Margin="0,8,0,0" Text="{Binding Message, FallbackValue=There is a new version available.}"
                           FontSize="16" Foreground="{StaticResource SolidColorBrush.Text.2}" TextWrapping="Wrap" />

                <Border Grid.Row="2" Margin="0,18,0,0" Padding="16" Background="{StaticResource SolidColorBrush.Background.3}"
                        BorderBrush="{StaticResource SolidColorBrush.Background.4}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding ReleaseTitle}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource SolidColorBrush.Text.1}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,6,0,0" Text="{Binding VersionText}" FontSize="16"
                                       Foreground="{StaticResource SolidColorBrush.Accent.Blue.2}" />
                        </StackPanel>

                        <TextBlock Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Top" Text="{Binding ReleaseDateText}" FontSize="15"
                                   Foreground="{StaticResource SolidColorBrush.Text.4}" />
                    </Grid>
                </Border>

                <Border Grid.Row="3" Margin="0,18,0,0" Padding="0" Background="{StaticResource SolidColorBrush.Background.3}" 
                        BorderBrush="{StaticResource SolidColorBrush.Background.4}" BorderThickness="1"
                        Visibility="{Binding HasPatchNotes, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="16,12" Background="{StaticResource SolidColorBrush.Background.4}">
                            <TextBlock Text="Patch Notes" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource SolidColorBrush.Text.1}" />
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl Margin="16,14,16,16" ItemsSource="{Binding Sections}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type viewModels:UpdateNoteSectionViewModel}">
                                        <StackPanel Margin="0,0,0,16">
                                            <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="Bold" Foreground="{Binding TitleBrush}"
                                                       Visibility="{Binding HasTitle, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Margin="0,0,0,6" Foreground="{StaticResource SolidColorBrush.Text.2}" TextWrapping="Wrap">
                                                            <Run Text="- " />
                                                            <Run Text="{Binding Path=., Mode=OneWay}" />
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="16,0,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Margin="0,0,0,8" Foreground="{StaticResource SolidColorBrush.Text.4}" Text="{Binding StatusText}"
                           Visibility="{Binding IsStatusVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ProgressBar Grid.Column="0" Height="6" Margin="0,0,20,0" IsIndeterminate="{Binding IsBusy}"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <Button Grid.Column="1" Width="150" Height="36" Margin="0,0,10,0" Click="RemindLater_Click"
                            Content="{Binding PostponeButtonText}" IsEnabled="{Binding AreButtonsEnabled}" />
                    <Button Grid.Column="2" Width="170" Height="36" Click="DownloadInstall_Click" Content="{Binding ActionButtonText}"
                            IsEnabled="{Binding AreButtonsEnabled}" Style="{StaticResource Style.Button.Attention}" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>